<form class="ttb-actors sheet item" autocomplete="off">
  <header class="ttb-actors-header sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="ttb-actors-header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" /></h1>
      <div class="ttb-actors-header-details">
        <label>Type</label><span style="color:var(--ttb-gold)">Spell</span>
      </div>
    </div>
  </header>
  <section class="ttb-item-body">
    <div class="ttb-item-fields">
      <label>Theory</label>
      <input type="text" name="system.theory" value="{{system.theory}}" placeholder="e.g. Elemental, Necromancy" />
      <label>TN</label>
      <input type="number" name="system.tn" value="{{system.tn}}" min="0" />
      <label>Range</label>
      <input type="text" name="system.range" value="{{system.range}}" placeholder="e.g. 8 yards, Touch" />
      <label>Duration</label>
      <input type="text" name="system.duration" value="{{system.duration}}" placeholder="e.g. Instant, Ongoing" />
    </div>
    <div class="ttb-item-text-section">
      <label>Immutos</label>
      <input type="text" name="system.immutos" value="{{system.immutos}}" placeholder="e.g. Fire, Increase TN" class="ttb-item-full-input" />
    </div>
    <div class="ttb-item-text-section">
      <label>Description</label>
      <textarea name="system.description" rows="5" placeholder="Spell effect and rules...">{{system.description}}</textarea>
    </div>
  </section>
</form>
