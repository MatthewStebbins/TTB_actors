<form class="ttb-actors sheet item" autocomplete="off">
  <header class="ttb-actors-header sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="ttb-actors-header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" /></h1>
      <div class="ttb-actors-header-details">
        <label>Type</label><span style="color:var(--ttb-gold)">Weapon</span>
      </div>
    </div>
  </header>
  <section class="ttb-item-body">

    <div class="ttb-item-fields ttb-item-fields-4col">
      <label>AP Cost</label>
      <input type="number" name="system.apCost" value="{{system.apCost}}" min="0" max="3" />

      <label>Range Type</label>
      <select name="system.rangeType">
        <option value="melee"  {{#if (eq system.rangeType "melee")}}selected{{/if}}>Melee</option>
        <option value="ranged" {{#if (eq system.rangeType "ranged")}}selected{{/if}}>Ranged</option>
        <option value="thrown" {{#if (eq system.rangeType "thrown")}}selected{{/if}}>Thrown</option>
      </select>

      <label>Attack Skill</label>
      <input type="text" name="system.attackSkill" value="{{system.attackSkill}}" placeholder="e.g. Pistol" />

      <label>Range</label>
      <input type="text" name="system.range" value="{{system.range}}" placeholder="e.g. y1, z12" />

      <label>Capacity</label>
      <input type="number" name="system.capacity" value="{{system.capacity}}" min="0" placeholder="0 = melee" />

      <label>Reload</label>
      <input type="number" name="system.reload" value="{{system.reload}}" min="0" />

      <label>Cost (Scrip)</label>
      <input type="number" name="system.cost" value="{{system.cost}}" min="0" />

      <label>Category</label>
      <select name="system.category">
        <option value="">— Select —</option>
        <option value="melee"      {{#if (eq system.category "melee")}}selected{{/if}}>Melee</option>
        <option value="heavy_melee" {{#if (eq system.category "heavy_melee")}}selected{{/if}}>Heavy Melee</option>
        <option value="flexible"   {{#if (eq system.category "flexible")}}selected{{/if}}>Flexible</option>
        <option value="pugilism"   {{#if (eq system.category "pugilism")}}selected{{/if}}>Pugilism</option>
        <option value="pneumatic"  {{#if (eq system.category "pneumatic")}}selected{{/if}}>Pneumatic</option>
        <option value="archery"    {{#if (eq system.category "archery")}}selected{{/if}}>Archery</option>
        <option value="pistol"     {{#if (eq system.category "pistol")}}selected{{/if}}>Pistol</option>
        <option value="long_arm"   {{#if (eq system.category "long_arm")}}selected{{/if}}>Long Arm</option>
        <option value="shotgun"    {{#if (eq system.category "shotgun")}}selected{{/if}}>Shotgun</option>
        <option value="heavy_gun"  {{#if (eq system.category "heavy_gun")}}selected{{/if}}>Heavy Gun</option>
      </select>

      <label>Equipped</label>
      <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} />
    </div>

    <div class="ttb-item-damage-row">
      <span class="ttb-damage-label">Damage</span>
      <div class="ttb-damage-track">
        <label>Weak</label>
        <input type="number" name="system.damageWeak"   value="{{system.damageWeak}}"   min="0" />
        <label>Moderate</label>
        <input type="number" name="system.damageMod"    value="{{system.damageMod}}"    min="0" />
        <label>Severe</label>
        <input type="number" name="system.damageSevere" value="{{system.damageSevere}}" min="0" />
      </div>
    </div>

    <div class="ttb-item-text-section">
      <label>Triggers</label>
      <textarea name="system.triggers" rows="3" placeholder="e.g. Ram Critical Strike: deal +1 damage per Ram in duel total">{{system.triggers}}</textarea>
    </div>

    <div class="ttb-item-text-section">
      <label>Special Rules</label>
      <textarea name="system.special" rows="2" placeholder="e.g. Capacity 6, Reload 1; ignores Hard to Wound">{{system.special}}</textarea>
    </div>

    <div class="ttb-item-text-section">
      <label>Description</label>
      <textarea name="system.description" rows="3" placeholder="Item description or lore...">{{system.description}}</textarea>
    </div>

  </section>
</form>
