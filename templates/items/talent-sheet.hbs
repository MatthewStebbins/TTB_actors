<form class="ttb-actors sheet item" autocomplete="off">
  <header class="ttb-actors-header sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="ttb-actors-header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" /></h1>
      <div class="ttb-actors-header-details">
        <label>Type</label><span style="color:var(--ttb-gold)">Talent</span>
      </div>
    </div>
  </header>
  <section class="ttb-item-body">
    <div class="ttb-item-fields">
      <label>Pursuit</label>
      <input type="text" name="system.pursuit" value="{{system.pursuit}}" placeholder="e.g. Gunslinger, General" />
      <label>Requirements</label>
      <input type="text" name="system.requirements" value="{{system.requirements}}" placeholder="e.g. Cunning 3, Pistol 2" />
    </div>
    <div class="ttb-item-text-section">
      <label>Description</label>
      <textarea name="system.description" rows="6" placeholder="Talent effect and rules...">{{system.description}}</textarea>
    </div>
  </section>
</form>
