<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <div class="ttb-sheet-title">
      <img src="{{actor.img}}" title="{{actor.name}}" class="ttb-sheet-img" />
      <div class="ttb-title-section">
        <h1 class="ttb-sheet-name">
          <input type="text" name="name" value="{{actor.name}}" />
        </h1>
        <p class="ttb-npc-rank">
          <input type="text" name="system.rank.title" value="{{rank.title}}" placeholder="Minion" />
          (Rank: <input type="number" name="system.rank.value" value="{{rank.value}}" />)
        </p>
      </div>
    </div>
  </header>

  <section class="ttb-stat-block">
    <h3 style="text-align: center; margin: 0 0 12px 0; font-size: 0.9em; text-transform: uppercase; letter-spacing: 0.5px; color: var(--ttb-burgundy);">Stat Block</h3>
    <div class="ttb-stat-grid">
      <div class="ttb-stat ttb-stat-primary">
        <label class="ttb-stat-label">Defense</label>
        <div class="ttb-stat-display">{{derived.defense}}</div>
      </div>
      <div class="ttb-stat ttb-stat-primary">
        <label class="ttb-stat-label">Willpower</label>
        <div class="ttb-stat-display">{{derived.willpower}}</div>
      </div>
      <div class="ttb-stat">
        <label class="ttb-stat-label">Walk</label>
        <div class="ttb-stat-display">{{derived.walk}}</div>
      </div>
      <div class="ttb-stat">
        <label class="ttb-stat-label">Charge</label>
        <div class="ttb-stat-display">{{derived.charge}}</div>
      </div>
      <div class="ttb-stat">
        <label class="ttb-stat-label">Height</label>
        <div class="ttb-stat-display">{{derived.height}}</div>
      </div>
      <div class="ttb-stat">
        <label class="ttb-stat-label">Initiative</label>
        <div class="ttb-stat-display">{{derived.initiative}}</div>
      </div>
    </div>
  </section>

  <section class="ttb-wounds-section">
    <h3>{{localize "TTB.Wounds"}}</h3>
    <div class="ttb-wounds-box">
      {{#each woundBoxes as |box index|}}
        <div class="ttb-wound-box {{#if box}}ttb-wound-active{{/if}}" data-index="{{index}}" title="Click to toggle"></div>
      {{/each}}
    </div>
    <div class="ttb-wounds-input">
      <input type="number" name="system.wounds.value" value="{{wounds.value}}" min="0" max="{{wounds.max}}" />
      / {{wounds.max}}
    </div>
  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <button class="item" data-tab="stat-block">{{localize "TTB.StatBlock"}}</button>
    <button class="item" data-tab="skills">{{localize "TTB.Skills"}}</button>
    <button class="item" data-tab="abilities">{{localize "TTB.Abilities"}}</button>
    <button class="item" data-tab="biography">{{localize "TTB.Description"}}</button>
  </nav>

  <section class="sheet-body">
    <!-- Stat Block Tab -->
    <div class="tab" data-tab="stat-block">
      <div class="ttb-npc-stat-block">
        <div class="ttb-attributes-grid">
          {{#each attributes as |attr|}}
            <div class="ttb-attribute-card">
              <div class="ttb-attr-header">
                {{attr.label}}
              </div>
              <div class="ttb-attr-value">
                <input type="number" name="system.attributes.{{attr.key}}.value" value="{{attr.value}}" min="-5" max="5" />
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    <!-- Skills Tab -->
    <div class="tab" data-tab="skills">
      <div class="ttb-skills-section">
        {{#each skillsByAttribute as |group attr|}}
          {{#if group.skills.length}}
            <div class="ttb-skill-group">
              <h4>{{group.label}}</h4>
              <table class="ttb-skills-table">
                <tbody>
                  {{#each group.skills as |skill|}}
                    <tr>
                      <td class="ttb-skill-name">{{skill.label}}</td>
                      <td class="ttb-skill-value">
                        <input type="number" name="system.skills.{{skill.key}}.value" value="{{skill.value}}" min="0" max="5" />
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{/if}}
        {{/each}}
      </div>
    </div>

    <!-- Abilities Tab -->
    <div class="tab" data-tab="abilities">
      <div class="ttb-abilities-section">
        {{#each abilities as |ability index|}}
          <div class="ttb-ability-item">
            <div class="ttb-ability-controls">
              <input type="text" class="ttb-ability-name" data-index="{{index}}" value="{{ability.name}}" placeholder="Ability Name" />
              <button class="ttb-ability-delete" data-index="{{index}}" type="button">{{localize "TTB.Delete"}}</button>
            </div>
            <textarea class="ttb-ability-description" data-index="{{index}}" placeholder="Ability description">{{ability.description}}</textarea>
          </div>
        {{/each}}
        <button class="ttb-ability-add" type="button">{{localize "TTB.AddAbility"}}</button>
      </div>
    </div>

    <!-- Description Tab -->
    <div class="tab" data-tab="biography">
      <textarea name="system.notes" class="ttb-notes-field">{{system.notes}}</textarea>
    </div>
  </section>
</form>
