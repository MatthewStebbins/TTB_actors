<form class="ttb-actors sheet" autocomplete="off">
  <!-- Header -->
  <header class="ttb-actors-header sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="ttb-actors-header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="ttb-actors-header-details">
        <label>Station</label>
        <input type="text" name="system.station" value="{{system.station}}" placeholder="e.g. Outcast" />
        <label>Aspect</label>
        <select name="system.aspect">
          {{#each aspectOptions}}
            <option value="{{value}}" {{#if (eq value ../system.aspect)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </header>

  <!-- Derived Stats Bar -->
  <div class="ttb-actors-derived">
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Defense</span>
      <span class="ttb-actors-derived-value">{{derived.defense}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Willpower</span>
      <span class="ttb-actors-derived-value">{{derived.willpower}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Walk</span>
      <span class="ttb-actors-derived-value">{{derived.walk}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Charge</span>
      <span class="ttb-actors-derived-value">{{derived.charge}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Height</span>
      <span class="ttb-actors-derived-value">{{derived.height}}</span>
    </div>
    <div class="ttb-actors-wounds">
      <span class="ttb-actors-derived-label">Wounds&nbsp;</span>
      <input class="ttb-actors-wounds-value" type="number" value="{{system.wounds.value}}" min="0" max="{{derived.woundsMax}}" />
      <span style="color:var(--ttb-gold);">&thinsp;/&thinsp;</span>
      <span class="ttb-actors-derived-value">{{derived.woundsMax}}</span>
    </div>
  </div>

  <!-- Tabs -->
  <nav class="sheet-tabs tabs">
    <a class="item" data-tab="attributes">Attributes</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="details">Details</a>
  </nav>

  <section class="sheet-body">
    <!-- Attributes Tab -->
    <div class="tab" data-tab="attributes">
      <div class="ttb-actors-attributes">
        {{#each attributes}}
          <div class="ttb-actors-attr">
            <label class="ttb-actors-attr-label">{{label}}</label>
            <input class="ttb-actors-attr-value" type="number" value="{{value}}" min="1" max="5" data-attr="{{key}}" />
          </div>
        {{/each}}
      </div>
    </div>

    <!-- Skills Tab -->
    <div class="tab" data-tab="skills">
      {{#each skillsByAttribute}}
        <div class="ttb-actors-skill-group">
          <h3 class="ttb-actors-skill-group-header">{{label}}</h3>
          <ul class="ttb-actors-skill-list">
            {{#each skills}}
              <li class="ttb-actors-skill-item">
                <label class="ttb-actors-skill-label">{{label}}</label>
                <input class="ttb-actors-skill-value" type="number" value="{{value}}" min="0" max="5" data-skill="{{key}}" />
              </li>
            {{/each}}
          </ul>
        </div>
      {{/each}}
    </div>

    <!-- Details Tab -->
    <div class="tab" data-tab="details">
      <div class="ttb-actors-details">
        <div>
          <label>Age</label>
          <input type="text" name="system.details.age" value="{{system.details.age}}" />
        </div>
        <div>
          <label>Gender</label>
          <input type="text" name="system.details.gender" value="{{system.details.gender}}" />
        </div>
        <div class="ttb-full-row">
          <label>Description</label>
          <textarea name="system.details.description" rows="6">{{system.details.description}}</textarea>
        </div>
      </div>
    </div>
  </section>
</form>
