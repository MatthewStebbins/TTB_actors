<form class="ttb-actors sheet" autocomplete="off">
  <!-- Header -->
  <header class="ttb-actors-header sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="ttb-actors-header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="ttb-actors-header-details">
        <label>Player</label>
        <input type="text" name="system.playerName" value="{{system.playerName}}" placeholder="Player name" />
        <label>Station</label>
        <input type="text" name="system.station" value="{{system.station}}" />
        <label>Aspect</label>
        <select name="system.aspect">
          {{#each aspectOptions}}
            <option value="{{value}}" {{#if (eq value ../system.aspect)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <label>Pursuit</label>
        <input type="text" name="system.pursuit" value="{{system.pursuit}}" placeholder="e.g. Gunslinger" />
        <label>Size</label>
        <input type="text" name="system.size" value="{{system.size}}" style="width:56px" />
      </div>
    </div>
  </header>

  <!-- Derived Stats Bar -->
  <div class="ttb-actors-derived">
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Defense</span>
      <span class="ttb-actors-derived-value">{{derived.defense}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Willpower</span>
      <span class="ttb-actors-derived-value">{{derived.willpower}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Walk</span>
      <span class="ttb-actors-derived-value">{{derived.walk}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Charge</span>
      <span class="ttb-actors-derived-value">{{derived.charge}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Height</span>
      <span class="ttb-actors-derived-value">{{derived.height}}</span>
    </div>
    <div class="ttb-actors-wounds">
      <span class="ttb-actors-derived-label">Wounds&nbsp;</span>
      <span class="ttb-actors-derived-value">{{system.wounds.value}}/{{derived.woundsMax}}</span>
    </div>
  </div>

  <!-- Wound Boxes -->
  <div class="ttb-wound-track">
    {{#each woundBoxes}}
      <button type="button"
        class="ttb-wound-box {{#if filled}}filled{{/if}} {{#unless active}}inactive{{/unless}}"
        data-index="{{index}}">
      </button>
    {{/each}}
    <div class="ttb-serious-wound">
      <label>Serious Wound</label>
      <input type="text" name="system.seriousWound" value="{{system.seriousWound}}" placeholder="Describe serious wound..." />
    </div>
  </div>

  <!-- Tabs -->
  <nav class="sheet-tabs tabs">
    <a class="item" data-tab="attributes">Attributes</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="destiny">Destiny</a>
    <a class="item" data-tab="pursuits">Pursuits</a>
    <a class="item" data-tab="equipment">Equipment</a>
  </nav>

  <section class="sheet-body">
    <!-- Attributes Tab -->
    <div class="tab" data-tab="attributes">
      <div class="ttb-actors-attributes">
        {{#each attributes}}
          <div class="ttb-actors-attr">
            <label class="ttb-actors-attr-label">{{label}}</label>
            <input class="ttb-actors-attr-value" type="number" value="{{value}}" min="1" max="5" data-attr="{{key}}" />
          </div>
        {{/each}}
      </div>
    </div>

    <!-- Skills Tab -->
    <div class="tab" data-tab="skills">
      {{#each skillsByAttribute}}
        <div class="ttb-actors-skill-group">
          <h3 class="ttb-actors-skill-group-header">{{label}}</h3>
          <ul class="ttb-actors-skill-list">
            {{#each skills}}
              <li class="ttb-actors-skill-item">
                <label class="ttb-actors-skill-label">{{label}}</label>
                <input class="ttb-actors-skill-value" type="number" value="{{value}}" min="0" max="5" data-skill="{{key}}" />
              </li>
            {{/each}}
          </ul>
        </div>
      {{/each}}
    </div>

    <!-- Destiny Tab -->
    <div class="tab" data-tab="destiny">
      <div class="ttb-destiny">
        <h3 class="ttb-section-header">Fate Spread</h3>
        <div class="ttb-destiny-spread">
          {{#each destinySpread}}
            <div class="ttb-fate-card">
              <div class="ttb-fate-suit">{{symbol}}</div>
              {{!-- No name= attrs: JS change listeners handle save to prevent array corruption --}}
              <input class="ttb-fate-value ttb-spread-value" type="text"
                data-index="{{index}}"
                value="{{value}}" placeholder="&mdash;" />
              <select class="ttb-spread-suit" data-index="{{index}}">
                <option value="" {{#if (eq suit "")}}selected{{/if}}>?</option>
                <option value="crow" {{#if (eq suit "crow")}}selected{{/if}}>&#9824; Crow</option>
                <option value="mask" {{#if (eq suit "mask")}}selected{{/if}}>&#9827; Mask</option>
                <option value="ram"  {{#if (eq suit "ram")}}selected{{/if}}>&#9829; Ram</option>
                <option value="tome" {{#if (eq suit "tome")}}selected{{/if}}>&#9830; Tome</option>
              </select>
            </div>
          {{/each}}
        </div>

        <h3 class="ttb-section-header">Destiny Steps</h3>
        <div class="ttb-destiny-steps">
          {{#each destinySteps}}
            <div class="ttb-destiny-step {{#if isCurrent}}current{{/if}} {{#if completed}}completed{{/if}}">
              <span class="ttb-step-num">{{number}}</span>
              {{!-- No name= attrs: JS change listeners handle save to prevent array corruption --}}
              <input class="ttb-step-text" type="text"
                data-index="{{index}}"
                value="{{text}}" placeholder="Destiny step..." />
              <button type="button" class="ttb-destiny-step-check" data-index="{{index}}"
                title="Toggle completed">{{#if completed}}&#10003;{{else}}&#9675;{{/if}}</button>
            </div>
          {{/each}}
        </div>

        <div class="ttb-destiny-current">
          <label>Current Step</label>
          <input type="number" name="system.destiny.currentStep"
            value="{{system.destiny.currentStep}}" min="1" max="5" style="width:48px" />
        </div>
      </div>
    </div>

    <!-- Pursuits & Talents Tab -->
    <div class="tab" data-tab="pursuits">
      <div class="ttb-pursuits-talents">
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Pursuits
            <button type="button" class="ttb-pursuit-add ttb-add-btn" title="Add pursuit">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>Pursuit</th><th>Session</th><th></th></tr></thead>
            <tbody>
              {{#each pursuits}}
                <tr>
                  {{!-- No name= attrs: JS change listeners handle save to prevent array corruption --}}
                  <td><input class="ttb-pursuit-name" type="text"
                    data-index="{{@index}}" data-field="name"
                    value="{{name}}" placeholder="e.g. Gunslinger" /></td>
                  <td><input class="ttb-pursuit-session" type="text"
                    data-index="{{@index}}" data-field="session"
                    value="{{session}}" placeholder="Session #" style="width:70px" /></td>
                  <td><button type="button" class="ttb-pursuit-delete ttb-delete-btn" data-index="{{@index}}">&#10005;</button></td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Talents
            <button type="button" class="ttb-talent-add ttb-add-btn" title="Add talent">+</button>
          </h3>
          {{#each talents}}
            <div class="ttb-talent-entry">
              <div class="ttb-talent-header">
                {{!-- No name= attrs: JS change listeners handle save to prevent array corruption --}}
                <input class="ttb-talent-name" type="text"
                  data-index="{{@index}}" data-field="name"
                  value="{{name}}" placeholder="Talent name" />
                <button type="button" class="ttb-talent-delete ttb-delete-btn" data-index="{{@index}}">&#10005;</button>
              </div>
              <textarea class="ttb-talent-desc"
                data-index="{{@index}}" data-field="description"
                rows="2" placeholder="Talent description...">{{description}}</textarea>
            </div>
          {{/each}}
          {{#unless talents.length}}
            <p class="ttb-empty-notice">No talents yet. Click + to add one.</p>
          {{/unless}}
        </div>
      </div>
    </div>

    <!-- Equipment Tab -->
    <div class="tab" data-tab="equipment">
      <div class="ttb-equipment">
        <!-- Weapons -->
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Weapons
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="weapon" title="Add weapon">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>E</th><th>Name</th><th>Skill</th><th>Dmg</th><th>Range</th><th>Special</th><th></th></tr></thead>
            <tbody>
              {{#each weapons}}
                <tr data-item-id="{{id}}">
                  <td><input type="checkbox" class="ttb-item-equipped" {{#if system.equipped}}checked{{/if}} /></td>
                  <td>{{name}}</td>
                  <td>{{system.attackSkill}}</td>
                  <td>{{system.damage}}</td>
                  <td>{{system.range}}</td>
                  <td>{{system.special}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&#10005;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <!-- Armor -->
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Armor
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="armor" title="Add armor">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>E</th><th>Name</th><th>Def Bonus</th><th>Special</th><th></th></tr></thead>
            <tbody>
              {{#each armors}}
                <tr data-item-id="{{id}}">
                  <td><input type="checkbox" class="ttb-item-equipped" {{#if system.equipped}}checked{{/if}} /></td>
                  <td>{{name}}</td>
                  <td>{{system.defenseBonus}}</td>
                  <td>{{system.special}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&#10005;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <!-- Inventory -->
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Inventory
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="gear" title="Add item">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>Name</th><th>Qty</th><th>Notes</th><th></th></tr></thead>
            <tbody>
              {{#each inventory}}
                <tr data-item-id="{{id}}">
                  <td>{{name}}</td>
                  <td>{{system.quantity}}</td>
                  <td>{{system.description}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&#10005;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <!-- Scrip -->
        <div class="ttb-scrip">
          <label>Scrip (Guilders)</label>
          <input type="number" name="system.equipment.scrip" value="{{system.equipment.scrip}}" min="0" />
        </div>
      </div>
    </div>
  </section>
</form>
