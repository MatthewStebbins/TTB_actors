<form class="ttb-actors sheet" autocomplete="off">
  <!-- Header -->
  <header class="ttb-actors-header sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="ttb-actors-header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="ttb-actors-header-details">
        <label>Player</label>
        <input type="text" name="system.playerName" value="{{system.playerName}}" placeholder="Player name" />
        <label>Station</label>
        <input type="text" name="system.station" value="{{system.station}}" />
        <label>Aspect</label>
        <select name="system.aspect">
          {{#each aspectOptions}}
            <option value="{{value}}" {{#if (eq value ../system.aspect)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <label>Pursuit</label>
        <input type="text" name="system.pursuit" value="{{system.pursuit}}" placeholder="e.g. Gunslinger" />
        <label>Size</label>
        <input type="text" name="system.size" value="{{system.size}}" style="width:56px" />
      </div>
    </div>
  </header>

  <!-- Derived Stats Bar -->
  <div class="ttb-actors-derived">
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Defense</span>
      <span class="ttb-actors-derived-value">{{derived.defense}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Willpower</span>
      <span class="ttb-actors-derived-value">{{derived.willpower}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Walk</span>
      <span class="ttb-actors-derived-value">{{derived.walk}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Charge</span>
      <span class="ttb-actors-derived-value">{{derived.charge}}</span>
    </div>
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Height</span>
      <span class="ttb-actors-derived-value">{{derived.height}}</span>
    </div>
    {{#if derived.soak}}
    <div class="ttb-actors-derived-item">
      <span class="ttb-actors-derived-label">Soak</span>
      <span class="ttb-actors-derived-value">+{{derived.soak}}</span>
    </div>
    {{/if}}
    <div class="ttb-actors-wounds">
      <span class="ttb-actors-derived-label">Wounds&nbsp;</span>
      <span class="ttb-actors-derived-value">{{system.wounds.value}}/{{derived.woundsMax}}</span>
    </div>
    <!-- Soulstones -->
    <div class="ttb-soulstones">
      <span class="ttb-actors-derived-label">Soulstones</span>
      <div class="ttb-soulstone-track">
        {{#each soulstoneDots}}
          <button type="button"
            class="ttb-soulstone-dot {{#if filled}}filled{{/if}}"
            data-index="{{index}}" title="Soulstone">&#9670;</button>
        {{/each}}
        <input type="number" name="system.soulstones.max" value="{{soulstoneMax}}"
          min="0" max="10" class="ttb-soulstone-max" title="Max soulstones" />
      </div>
    </div>
  </div>

  <!-- Wound Boxes -->
  <div class="ttb-wound-track">
    {{#each woundBoxes}}
      <button type="button"
        class="ttb-wound-box {{#if filled}}filled{{/if}} {{#unless active}}inactive{{/unless}}"
        data-index="{{index}}">
      </button>
    {{/each}}
    <div class="ttb-serious-wound">
      <label>Serious Wound</label>
      <input type="text" name="system.seriousWound" value="{{system.seriousWound}}" placeholder="Describe serious wound..." />
    </div>
  </div>

  <!-- Conditions Strip -->
  <div class="ttb-conditions-strip">
    <div class="ttb-condition ttb-condition-number">
      <label>Burning</label>
      <input type="number" name="system.conditions.burning" value="{{conditions.burning}}" min="0" max="4" />
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.slow}}active{{/if}}">
      <input type="checkbox" name="system.conditions.slow" {{#if conditions.slow}}checked{{/if}} id="cond-slow" />
      <label for="cond-slow">Slow</label>
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.fast}}active{{/if}}">
      <input type="checkbox" name="system.conditions.fast" {{#if conditions.fast}}checked{{/if}} id="cond-fast" />
      <label for="cond-fast">Fast</label>
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.stunned}}active{{/if}}">
      <input type="checkbox" name="system.conditions.stunned" {{#if conditions.stunned}}checked{{/if}} id="cond-stunned" />
      <label for="cond-stunned">Stunned</label>
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.paralyzed}}active{{/if}}">
      <input type="checkbox" name="system.conditions.paralyzed" {{#if conditions.paralyzed}}checked{{/if}} id="cond-paralyzed" />
      <label for="cond-paralyzed">Paralyzed</label>
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.distracted}}active{{/if}}">
      <input type="checkbox" name="system.conditions.distracted" {{#if conditions.distracted}}checked{{/if}} id="cond-distracted" />
      <label for="cond-distracted">Distracted</label>
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.immobilized}}active{{/if}}">
      <input type="checkbox" name="system.conditions.immobilized" {{#if conditions.immobilized}}checked{{/if}} id="cond-immobilized" />
      <label for="cond-immobilized">Immobilized</label>
    </div>
    <div class="ttb-condition ttb-condition-number">
      <label>Focused</label>
      <input type="number" name="system.conditions.focused" value="{{conditions.focused}}" min="0" max="10" />
    </div>
    <div class="ttb-condition ttb-condition-bool {{#if conditions.defensive}}active{{/if}}">
      <input type="checkbox" name="system.conditions.defensive" {{#if conditions.defensive}}checked{{/if}} id="cond-defensive" />
      <label for="cond-defensive">Defensive</label>
    </div>
  </div>

  <!-- Tabs -->
  <nav class="sheet-tabs tabs">
    <a class="item" data-tab="attributes">Attributes</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="destiny">Destiny</a>
    <a class="item" data-tab="grimoire">Grimoire</a>
    <a class="item" data-tab="pursuits">Pursuits</a>
    <a class="item" data-tab="equipment">Equipment</a>
    <a class="item" data-tab="biography">Biography</a>
    <a class="item" data-tab="fate">Fate Deck</a>
  </nav>

  <section class="sheet-body">
    <!-- Attributes Tab -->
    <div class="tab" data-tab="attributes">
      <div class="ttb-actors-attributes">
        {{#each attributes}}
          <div class="ttb-actors-attr">
            <label class="ttb-actors-attr-label">{{label}}</label>
            <input class="ttb-actors-attr-value" type="number" value="{{value}}" min="1" max="5" data-attr="{{key}}" />
            <div class="ttb-attr-suit-row">
              {{#each suitButtons}}
                <button type="button"
                  class="ttb-attr-suit-btn{{#if active}} active{{/if}}"
                  data-attr="{{../key}}" data-suit="{{value}}"
                  title="{{label}}">{{symbol}}</button>
              {{/each}}
            </div>
          </div>
        {{/each}}
      </div>
    </div>

    <!-- Skills Tab -->
    <div class="tab" data-tab="skills">
      {{#each skillsByAttribute}}
        <div class="ttb-actors-skill-group">
          <h3 class="ttb-actors-skill-group-header">{{label}}</h3>
          <ul class="ttb-actors-skill-list">
            {{#each skills}}
              <li class="ttb-actors-skill-item">
                <input type="checkbox" class="ttb-skill-practiced" data-skill="{{key}}"
                  {{#if practiced}}checked{{/if}} title="Practiced this session" />
                <label class="ttb-actors-skill-label">{{label}}</label>
                <input class="ttb-actors-skill-value" type="number" value="{{value}}" min="0" max="5" data-skill="{{key}}" />
                <span class="ttb-skill-total" title="{{attrVal}} + {{value}}">{{total}}</span>
                <input class="ttb-skill-triggers" type="text" value="{{triggers}}" data-skill="{{key}}"
                  placeholder="Triggers..." title="Suit triggers for this skill" />
              </li>
            {{/each}}
          </ul>
        </div>
      {{/each}}
    </div>

    <!-- Destiny Tab -->
    <div class="tab" data-tab="destiny">
      <div class="ttb-destiny">
        <h3 class="ttb-section-header">Fate Spread</h3>
        <div class="ttb-destiny-spread">
          {{#each destinySpread}}
            <div class="ttb-fate-card">
              <div class="ttb-fate-suit">{{symbol}}</div>
              <input class="ttb-fate-value" type="text"
                name="system.destiny.spread.{{index}}.value"
                value="{{value}}" placeholder="--" />
              <select name="system.destiny.spread.{{index}}.suit">
                <option value="" {{#if (eq suit "")}}selected{{/if}}>?</option>
                <option value="crow" {{#if (eq suit "crow")}}selected{{/if}}>&#9824; Crow</option>
                <option value="mask" {{#if (eq suit "mask")}}selected{{/if}}>&#9827; Mask</option>
                <option value="ram"  {{#if (eq suit "ram")}}selected{{/if}}>&#9829; Ram</option>
                <option value="tome" {{#if (eq suit "tome")}}selected{{/if}}>&#9830; Tome</option>
              </select>
            </div>
          {{/each}}
        </div>

        <h3 class="ttb-section-header">Destiny Steps</h3>
        <div class="ttb-destiny-steps">
          {{#each destinySteps}}
            <div class="ttb-destiny-step {{#if isCurrent}}current{{/if}} {{#if completed}}completed{{/if}}">
              <span class="ttb-step-num">{{number}}</span>
              <input type="text"
                name="system.destiny.steps.{{index}}.text"
                value="{{text}}" placeholder="Destiny step..." />
              <button type="button" class="ttb-destiny-step-check" data-index="{{index}}"
                title="Toggle completed">{{#if completed}}&#10003;{{else}}&#9675;{{/if}}</button>
            </div>
          {{/each}}
        </div>

        <div class="ttb-destiny-current">
          <label>Current Step</label>
          <input type="number" name="system.destiny.currentStep"
            value="{{system.destiny.currentStep}}" min="1" max="5" style="width:48px" />
        </div>

        <!-- Personal Agenda -->
        <div class="ttb-personal-agenda">
          <h3 class="ttb-section-header">Personal Agenda
            <span class="ttb-agenda-note">(earn scrip on completion)</span>
          </h3>
          <div class="ttb-agenda-row">
            <textarea name="system.destiny.agenda" rows="2"
              placeholder="Short-term personal goal for this session...">{{destinyAgenda}}</textarea>
            <label class="ttb-agenda-complete-label">
              <input type="checkbox" name="system.destiny.agendaComplete"
                {{#if destinyAgendaComplete}}checked{{/if}} />
              Complete
            </label>
          </div>
        </div>
      </div>
    </div>

    <!-- Grimoire Tab -->
    <div class="tab" data-tab="grimoire">
      <div class="ttb-grimoire">
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Grimoire
            <button type="button" class="ttb-grimoire-add ttb-add-btn" title="Add spell">+</button>
          </h3>
          <p class="ttb-grimoire-hint">Record spells and magical effects for Arcanists, Resurrectionists, and other magic users.</p>
          {{#if grimoireEmpty}}
            <p class="ttb-empty-notice">No spells recorded yet. Click + to add one.</p>
          {{else}}
            {{#each grimoire}}
              <div class="ttb-grimoire-entry" data-index="{{@index}}">
                <div class="ttb-grimoire-header">
                  <input type="text" class="ttb-grimoire-field ttb-grimoire-theory"
                    placeholder="Theory (e.g. Necromancy)" value="{{theory}}"
                    data-grimoire-index="{{@index}}" data-grimoire-field="theory" />
                  <input type="text" class="ttb-grimoire-field ttb-grimoire-name"
                    placeholder="Spell / Effect name" value="{{name}}"
                    data-grimoire-index="{{@index}}" data-grimoire-field="name" />
                  <button type="button" class="ttb-grimoire-delete ttb-delete-btn" data-index="{{@index}}">&times;</button>
                </div>
                <div class="ttb-grimoire-stats">
                  <span>
                    <label>Cost</label>
                    <input type="text" class="ttb-grimoire-field" value="{{cost}}"
                      placeholder="e.g. 1 AP" data-grimoire-index="{{@index}}" data-grimoire-field="cost" />
                  </span>
                  <span>
                    <label>Range</label>
                    <input type="text" class="ttb-grimoire-field" value="{{range}}"
                      placeholder="e.g. 6&#39;" data-grimoire-index="{{@index}}" data-grimoire-field="range" />
                  </span>
                  <span>
                    <label>Duration</label>
                    <input type="text" class="ttb-grimoire-field" value="{{duration}}"
                      placeholder="e.g. Instant" data-grimoire-index="{{@index}}" data-grimoire-field="duration" />
                  </span>
                </div>
                <textarea class="ttb-grimoire-desc" rows="2"
                  placeholder="Effect description..."
                  data-grimoire-index="{{@index}}" data-grimoire-field="description">{{description}}</textarea>
              </div>
            {{/each}}
          {{/if}}
        </div>
      </div>
    </div>

    <!-- Pursuits, Talents, Manifested Powers, and Other Abilities Tab -->
    <div class="tab" data-tab="pursuits">
      <div class="ttb-pursuits-talents">

        <!-- Pursuits — full width -->
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Pursuits
            <button type="button" class="ttb-pursuit-add ttb-add-btn" title="Add pursuit">+</button>
          </h3>
          {{#if pursuitsEmpty}}
            <p class="ttb-empty-notice">No pursuits yet. Click + to add one.</p>
          {{else}}
          <table class="ttb-table">
            <thead><tr><th>Pursuit</th><th>Session</th><th></th></tr></thead>
            <tbody>
              {{#each pursuits}}
                <tr>
                  <td><input type="text" name="system.pursuits.{{@index}}.name" value="{{name}}" placeholder="e.g. Gunslinger" /></td>
                  <td><input type="text" name="system.pursuits.{{@index}}.session" value="{{session}}" placeholder="Session #" style="width:70px" /></td>
                  <td><button type="button" class="ttb-pursuit-delete ttb-delete-btn" data-index="{{@index}}">&times;</button></td>
                </tr>
              {{/each}}
            </tbody>
          </table>
          {{/if}}
        </div>

        <!-- Talents + Other Abilities — 2 columns -->
        <div class="ttb-pursuits-cols">
          <div class="ttb-section">
            <h3 class="ttb-section-header">
              Talents
              <button type="button" class="ttb-talent-add ttb-add-btn" title="Add talent">+</button>
            </h3>
            {{#if talentsEmpty}}
              <p class="ttb-empty-notice">No talents yet. Click + to add one.</p>
            {{else}}
              {{#each talents}}
                <div class="ttb-talent-entry">
                  <div class="ttb-talent-header">
                    <input type="text" name="system.talents.{{@index}}.name" value="{{name}}" placeholder="Talent name" />
                    <button type="button" class="ttb-talent-delete ttb-delete-btn" data-index="{{@index}}">&times;</button>
                  </div>
                  <textarea name="system.talents.{{@index}}.description" rows="2" placeholder="Talent description...">{{description}}</textarea>
                </div>
              {{/each}}
            {{/if}}
          </div>

          <div class="ttb-section">
            <h3 class="ttb-section-header ttb-other-abilities-header">
              Other Abilities
              <button type="button" class="ttb-ability-add ttb-add-btn" title="Add ability">+</button>
            </h3>
            <p class="ttb-other-abilities-hint">Origin abilities, Station perks, species traits, and other innate capabilities.</p>
            {{#if otherAbilitiesEmpty}}
              <p class="ttb-empty-notice">No other abilities yet. Click + to add one.</p>
            {{else}}
              {{#each otherAbilities}}
                <div class="ttb-talent-entry ttb-ability-entry">
                  <div class="ttb-talent-header">
                    <input type="text" name="system.otherAbilities.{{@index}}.name" value="{{name}}" placeholder="Ability name" />
                    <button type="button" class="ttb-ability-delete ttb-delete-btn" data-index="{{@index}}">&times;</button>
                  </div>
                  <textarea name="system.otherAbilities.{{@index}}.description" rows="2" placeholder="Ability description...">{{description}}</textarea>
                </div>
              {{/each}}
            {{/if}}
          </div>
        </div>

        <!-- Manifested Powers — full width below -->
        <div class="ttb-section">
          <h3 class="ttb-section-header ttb-manifested-header">
            Manifested Powers
            <button type="button" class="ttb-power-add ttb-add-btn" title="Add manifested power">+</button>
          </h3>
          {{#if manifestedPowersEmpty}}
            <p class="ttb-empty-notice">No manifested powers yet - gained by completing Destiny steps.</p>
          {{else}}
            {{#each manifestedPowers}}
              <div class="ttb-talent-entry ttb-power-entry">
                <div class="ttb-talent-header">
                  <input type="text" name="system.manifestedPowers.{{@index}}.name" value="{{name}}" placeholder="Power name" />
                  <button type="button" class="ttb-power-delete ttb-delete-btn" data-index="{{@index}}">&times;</button>
                </div>
                <textarea name="system.manifestedPowers.{{@index}}.description" rows="2" placeholder="Power description...">{{description}}</textarea>
              </div>
            {{/each}}
          {{/if}}
        </div>

      </div>
    </div>

    <!-- Equipment Tab -->
    <div class="tab" data-tab="equipment">
      <div class="ttb-equipment">
        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Weapons
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="weapon" title="Add weapon">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>E</th><th>Name</th><th>AP</th><th>Skill</th><th>Dmg</th><th>Range</th><th></th></tr></thead>
            <tbody>
              {{#each weapons}}
                <tr data-item-id="{{id}}">
                  <td><input type="checkbox" class="ttb-item-equipped" {{#if system.equipped}}checked{{/if}} /></td>
                  <td><a class="ttb-item-name-link">{{name}}</a></td>
                  <td>{{system.apCost}}</td>
                  <td>{{system.attackSkill}}</td>
                  <td>{{displayDamage}}</td>
                  <td>{{system.range}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&times;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Armor
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="armor" title="Add armor">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>E</th><th>Name</th><th>Def Bonus</th><th>Soak</th><th>Special</th><th></th></tr></thead>
            <tbody>
              {{#each armors}}
                <tr data-item-id="{{id}}">
                  <td><input type="checkbox" class="ttb-item-equipped" {{#if system.equipped}}checked{{/if}} /></td>
                  <td><a class="ttb-item-name-link">{{name}}</a></td>
                  <td>{{system.defenseBonus}}</td>
                  <td>{{#if system.soak}}+{{system.soak}}{{else}}—{{/if}}</td>
                  <td>{{system.special}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&times;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Inventory
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="gear" title="Add item">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>Name</th><th>Qty</th><th>Notes</th><th></th></tr></thead>
            <tbody>
              {{#each inventory}}
                <tr data-item-id="{{id}}">
                  <td><a class="ttb-item-name-link">{{name}}</a></td>
                  <td>{{system.quantity}}</td>
                  <td>{{system.description}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&times;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="ttb-scrip">
          <label>Scrip (Guilders)</label>
          <input type="number" name="system.equipment.scrip" value="{{system.equipment.scrip}}" min="0" />
        </div>

        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Talents
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="talent" title="Add talent">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>Name</th><th>Pursuit</th><th>Requirements</th><th></th></tr></thead>
            <tbody>
              {{#each talentItems}}
                <tr data-item-id="{{id}}">
                  <td><a class="ttb-item-name-link">{{name}}</a></td>
                  <td>{{system.pursuit}}</td>
                  <td>{{system.requirements}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&times;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="ttb-section">
          <h3 class="ttb-section-header">
            Spells
            <button type="button" class="ttb-item-create ttb-add-btn" data-type="spell" title="Add spell">+</button>
          </h3>
          <table class="ttb-table">
            <thead><tr><th>Name</th><th>Theory</th><th>TN</th><th>Range</th><th>Duration</th><th></th></tr></thead>
            <tbody>
              {{#each spellItems}}
                <tr data-item-id="{{id}}">
                  <td><a class="ttb-item-name-link">{{name}}</a></td>
                  <td>{{system.theory}}</td>
                  <td>{{system.tn}}</td>
                  <td>{{system.range}}</td>
                  <td>{{system.duration}}</td>
                  <td class="ttb-item-controls">
                    <button type="button" class="ttb-item-edit" title="Edit">&#9998;</button>
                    <button type="button" class="ttb-item-delete" title="Delete">&times;</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

      </div>
    </div>

    <!-- Biography Tab -->
    <div class="tab" data-tab="biography">
      <div class="ttb-biography">
        <div class="ttb-bio-fields">
          <label>Allegiance</label>
          <select name="system.allegiance">
            <option value="">-- Select --</option>
            {{#each allegianceOptions}}
              <option value="{{value}}" {{#if (eq value ../system.allegiance)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>

          <label>Age</label>
          <input type="text" name="system.details.age" value="{{system.details.age}}" placeholder="Age" style="width:80px" />

          <label>Gender</label>
          <input type="text" name="system.details.gender" value="{{system.details.gender}}" placeholder="Gender / pronouns" />
        </div>

        <div class="ttb-bio-section">
          <label class="ttb-bio-label">Appearance</label>
          <textarea name="system.details.appearance" rows="3"
            placeholder="Describe your character appearance...">{{system.details.appearance}}</textarea>
        </div>

        <div class="ttb-bio-section">
          <label class="ttb-bio-label">Background</label>
          <textarea name="system.details.background" rows="4"
            placeholder="Describe your character history and background...">{{system.details.background}}</textarea>
        </div>

        <div class="ttb-bio-section">
          <label class="ttb-bio-label">Notes</label>
          <textarea name="system.notes" rows="5"
            placeholder="Session notes, NPC contacts, loose ends...">{{system.notes}}</textarea>
        </div>
      </div>
    </div>

    <!-- Fate Deck Tab -->
    <div class="tab" data-tab="fate">
      <div class="ttb-fate-deck">

        <!-- World deck missing -->
        {{#if worldDeckMissing}}
          <div class="ttb-fate-missing">
            <p class="ttb-fate-missing-note">No communal Fate Deck found for this world.</p>
            <p class="ttb-fate-missing-note">Ask your Fatemaster to create one via <strong>TTB GM Tools</strong> in the Scene Controls.</p>
          </div>
        {{/if}}

        {{#unless worldDeckMissing}}

          <!-- Counters + open buttons -->
          <div class="ttb-fate-controls">
            <div class="ttb-fate-counter">
              <span class="ttb-fate-counter-label">Fate Deck</span>
              <span class="ttb-fate-counter-value">{{deckSize}}</span>
            </div>
            <div class="ttb-fate-counter">
              <span class="ttb-fate-counter-label">Discard</span>
              <span class="ttb-fate-counter-value">{{pileSize}}</span>
            </div>
            <div class="ttb-fate-counter">
              <span class="ttb-fate-counter-label">My Hand</span>
              <span class="ttb-fate-counter-value">{{handSize}}</span>
            </div>
            <div class="ttb-fate-open-btns">
              <button type="button" class="ttb-hand-open">Open My Hand</button>
            </div>
          </div>

          <!-- Duel setup row -->
          <div class="ttb-duel-setup">
            <div class="ttb-duel-row">
              <label class="ttb-duel-label">Skill</label>
              <select class="ttb-duel-skill">
                <option value="">— no skill —</option>
                {{#each skillOptions}}
                  <option value="{{key}}"{{#if selected}} selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
              <label class="ttb-duel-label">TN</label>
              <input type="number" class="ttb-duel-tn" value="{{duelTN}}" min="1" max="99" />
              <div class="ttb-modifier-row">
                <label class="ttb-duel-label">Fate</label>
                <button type="button" class="ttb-modifier-minus" title="Add Negative Fate Modifier">&minus;</button>
                <span class="ttb-modifier-value{{#if duelModifierPositive}} ttb-mod-positive{{/if}}{{#if duelModifierNegative}} ttb-mod-negative{{/if}}">{{duelModifierDisplay}}</span>
                <button type="button" class="ttb-modifier-plus" title="Add Positive Fate Modifier">+</button>
                <button type="button" class="ttb-modifier-reset" title="Reset modifier">&times;</button>
              </div>
              <button type="button" class="ttb-deck-flip">&#9824; Flip</button>
            </div>
          </div>

          <!-- Last flip result -->
          {{#if lastFlip}}
            <div class="ttb-flip-result-section">
              <div class="ttb-fate-flip-card ttb-suit-{{lastFlip.suit}}{{#if lastFlip.isRedJoker}} ttb-joker-red{{/if}}{{#if lastFlip.isBlackJoker}} ttb-joker-black{{/if}}">
                <span class="ttb-flip-symbol">{{lastFlip.symbol}}</span>
                <span class="ttb-flip-label">{{lastFlip.label}}</span>
                <span class="ttb-flip-tn">+{{lastFlip.tnValue}}</span>
              </div>
              <div class="ttb-flip-math">
                {{lastFlip.tnValue}} + AV {{lastFlip.av}} = <strong>{{lastFlip.total}}</strong> vs TN {{lastFlip.tn}}
              </div>
              <div class="ttb-flip-outcome{{#if lastFlip.success}} ttb-flip-success{{else}} ttb-flip-failure{{/if}}">
                {{#if lastFlip.success}}
                  &#10003; Success{{#if lastFlip.hasMos}} (MoS {{lastFlip.mos}}){{/if}}
                {{else}}
                  &#10007; Failure{{#if lastFlip.hasMof}} (MoF {{lastFlip.mosAbs}}){{/if}}
                {{/if}}
              </div>
              {{#if lastFlip.isRedJoker}}
                <div class="ttb-joker-note">&#9733; Critical Success &mdash; triggers on any suit; cannot be Cheated</div>
              {{/if}}
              {{#if lastFlip.isBlackJoker}}
                <div class="ttb-joker-note">&#9888; Critical Failure &mdash; Bad Luck Twist; cannot be Cheated</div>
              {{/if}}
              {{#unless lastFlip.canCheat}}
                <div class="ttb-cheat-disabled">Cannot Cheat Fate on this flip.</div>
              {{/unless}}
            </div>
          {{else}}
            <div class="ttb-fate-no-flip">
              <p>Set up a duel above and click <strong>&#9824; Flip</strong> to draw.</p>
            </div>
          {{/if}}

          <!-- GM controls removed — use TTB GM Tools in Scene Controls -->

        {{/unless}}

        <!-- Control Hand missing -->
        {{#if handMissing}}
          <div class="ttb-fate-missing">
            <p>Control Hand not found.</p>
            <button type="button" class="ttb-control-hand-create">Create My Control Hand</button>
          </div>
        {{/if}}

        <!-- Control Hand grid -->
        {{#unless handEmpty}}
          <div class="ttb-hand-section">
            <h3 class="ttb-section-header">Control Hand</h3>
            <div class="ttb-hand-grid">
              {{#each hand}}
                <div class="ttb-hand-card ttb-suit-{{suit}}{{#if isRedJoker}} ttb-joker-red{{/if}}{{#if isBlackJoker}} ttb-joker-black{{/if}}">
                  <span class="ttb-hand-card-symbol">{{symbol}}</span>
                  <span class="ttb-hand-card-name">{{label}}</span>
                  {{#if ../canCheat}}
                    <button type="button" class="ttb-hand-play" data-card-id="{{id}}"
                      title="Cheat Fate &mdash; replace your flip with this card">Cheat</button>
                  {{else}}
                    <span class="ttb-cheat-disabled" title="Cannot Cheat Fate on this flip">Cheat</span>
                  {{/if}}
                </div>
              {{/each}}
            </div>
          </div>
        {{/unless}}

      </div>
    </div>

  </section>
</form>
