{"_id": "guard-dog", "name": "Guard Dog", "type": "fatemaster", "system": {"rank": {"title": "Peon", "value": 4}, "types": "Living, Beast, Hound", "aspects": {"might": 1, "grace": 0, "speed": 2, "resilience": 0, "charm": 0, "cunning": -2, "intellect": -2, "tenacity": 0}, "derived": {"defense": "5 (9)", "willpower": "2 (6)", "walk": "5", "charge": "6", "height": "1", "initiative": "4 (8)"}, "wounds": {"value": 0, "max": 4}, "skills": {"evade": {"value": 3}, "intimidation": {"value": 1}, "notice": {"value": 2}, "pugilism": {"value": 3}, "track": {"value": 3}, "wilderness": {"value": 2}}, "abilities": [{"name": "Hunting Dogs", "description": "Enemy characters receive -1 Df while within a1 of this character."}, {"name": "Unimpeded", "description": "This character ignores penalties for terrain while taking Movement Actions."}], "actions": ["(1) Snapping Jaws (Pugilism) | AV: 4 (8) | Rg: y1 | Resist: Df | Target suffers 1/3/4 damage. This attack gains +2 AV when taken as part of a disengaging strike."], "notes": "Guard dogs were among the first animals brought to Malifaux by the Guild, valued for their ability to detect Neverborn by scent and serve as cheap sentries."}}
{"_id": "guild-guardsman", "name": "Guild Guardsman", "type": "fatemaster", "system": {"rank": {"title": "Minion", "value": 5}, "types": "Living, Guardsman", "aspects": {"might": 1, "grace": 2, "speed": 0, "resilience": 0, "charm": -1, "cunning": -1, "intellect": -1, "tenacity": 3}, "derived": {"defense": "4 (9)", "willpower": "5 (10)", "walk": "4", "charge": "4", "height": "2", "initiative": "2 (7)"}, "wounds": {"value": 0, "max": 5}, "skills": {"athletics": {"value": 1}, "convince": {"value": 1}, "evade": {"value": 3}, "labor": {"value": 3}, "notice": {"value": 2}, "pistol": {"value": 2}, "stealth": {"value": 1}, "toughness": {"value": 1}}, "abilities": [{"name": "Armor +1", "description": "Reduce all damage suffered by this character by 1, to a minimum of 1."}], "actions": ["(1) Standard Issue Sword (Melee) | AV: 4 (9) | Rg: y2 | Resist: Df | Target suffers 2/3/4 damage. Ram Critical Strike: When damaging the target, this attack deals +1 damage for each Ram in the final duel total.", "(1) Collier Navy (Pistol) | AV: 4 (9) | Rg: z12 | Resist: Df | Target suffers 2/3/4 damage. Capacity 6, Reload 2. Mask Arrest: After succeeding, the target gains Arrest Condition until the end of its next turn."], "notes": "The Guild Guard is the constabulary arm of the Guild, responsible for law enforcement and protecting Guild strongholds."}}
{"_id": "guard-sergeant", "name": "Guard Sergeant", "type": "fatemaster", "system": {"rank": {"title": "Enforcer", "value": 7}, "types": "Living, Guardsman", "aspects": {"might": 2, "grace": 2, "speed": 1, "resilience": 3, "charm": 2, "cunning": 1, "intellect": 0, "tenacity": 3}, "derived": {"defense": "4 (11)", "willpower": "5 (12)", "walk": "5", "charge": "5", "height": "2", "initiative": "3 (10)"}, "wounds": {"value": 0, "max": 8}, "skills": {"evade": {"value": 3}, "labor": {"value": 3}, "intimidation": {"value": 3}, "leadership": {"value": 3}, "notice": {"value": 2}, "pistol": {"value": 3}, "toughness": {"value": 2}, "track": {"value": 1}}, "abilities": [{"name": "Armor +1", "description": "Reduce all damage suffered by this character by 1, to a minimum of 1."}, {"name": "Frightening Authority", "description": "Other friendly Guardsmen characters within a6 gain +1 to Willpower duels."}, {"name": "Attennn-Hut!", "description": "Other friendly Guardsmen within a6 gain +1 Rank Value and are immune to Slow."}], "actions": ["(1) Breaching Axe (Heavy Melee) | AV: 5 (12) | Rg: y2 | Resist: Df | Target suffers 2/3/4 damage. Ram Critical Strike: When damaging, deals +1 damage per Ram.", "(1) Collier Single Action Army (Pistol) | AV: 5 (12) | Rg: z12 | Resist: Df | Target suffers 2/3/4 damage. Capacity 6, Reload 2.", "(0) Shout Orders (Leadership) | Target friendly Guardsman within 10 yards immediately performs a (1) Action."], "notes": "Guild Guard veterans promoted to Sergeant after demonstrating leadership in combat."}}
