{"_id": "nephilim-hunter", "name": "Nephilim Hunter", "type": "fatemaster", "system": {"rank": {"title": "Enforcer", "value": 7}, "types": "Living", "aspects": {"might": 1, "grace": 3, "speed": 2, "resilience": 2, "charm": 1, "cunning": 2, "intellect": -1, "tenacity": 2}, "derived": {"defense": "4 (11)", "willpower": "5 (12)", "walk": "5", "charge": "6", "height": "2", "initiative": "5 (12)"}, "wounds": {"value": 0, "max": 8}, "skills": {"athletics": {"value": 2}, "carouse": {"value": 2}, "centering": {"value": 3}, "gambling": {"value": 2}, "intimidation": {"value": 3}, "notice": {"value": 3}, "pistol": {"value": 4}, "stealth": {"value": 2}, "toughness": {"value": 3}, "track": {"value": 4}, "wilderness": {"value": 2}}, "abilities": [{"name": "Black Blood Resistance", "description": "Reduce all Black Blood damage by 1 (minimum 0)."}, {"name": "Gunfighter", "description": "May use Pistols as if Range y2."}, {"name": "Stubborn", "description": "Enemy characters suffer - to attack flips resisted by Willpower."}], "actions": ["(1) Weshorn & Smitte #3 (Pistol) | AV: 7 (14) | Rg: y2 or z10 | Resist: Df | Target suffers 2/3/4 damage. Capacity 6, Reload 1. Ram Critical Strike: +1 per Ram. Mask Trigger Happy: Take another Ranged attack.", "(2) Rapid Fire | Discard Twist to take three (1) AP attacks vs single target.", "(0) Shrug Off | Discard card to end a Condition.", "(0) Big Damn Hero | If outnumbered or vs Nephilim, discard card for 1 General AP."], "notes": "Freelance bounty hunters with Guild backing, authorized to hunt and destroy Nephilim."}}
{"_id": "death-marshal", "name": "Death Marshal", "type": "fatemaster", "system": {"rank": {"title": "Enforcer", "value": 8}, "types": "Living, Death Marshal", "aspects": {"might": 2, "grace": 2, "speed": 1, "resilience": 3, "charm": -2, "cunning": 1, "intellect": 1, "tenacity": 2}, "derived": {"defense": "4 (12)", "willpower": "5 (13)", "walk": "5", "charge": "5", "height": "2", "initiative": "4 (12)"}, "wounds": {"value": 0, "max": 9}, "skills": {"convince": {"value": 2}, "centering": {"value": 3}, "deceive": {"value": 3}, "evade": {"value": 2}, "labor": {"value": 4}, "intimidation": {"value": 3}, "leadership": {"value": 1}, "labor": {"value": 3}, "necromancy": {"value": 3}, "notice": {"value": 3}, "pistol": {"value": 4}, "scrutiny": {"value": 2}, "toughness": {"value": 3}, "thrownWeapons": {"value": 3}, "track": {"value": 4}, "wilderness": {"value": 1}}, "abilities": [{"name": "Hard to Wound +1", "description": "Damage flips against this character suffer -."}, {"name": "Fear Not Death", "description": "This character's corpse can never be reanimated. May render target remains unfit for reanimation."}], "actions": ["(1) Peacebringer (Pistol) | AV: 6 (14) | Rg: z10 | Resist: Df | Target suffers 2/3/5 damage. Grants + to Intimidate. Capacity 6, Reload 1. Ram Critical Strike: +1 per Ram.", "(1) Peacebringer Bayonet (Melee) | AV: 5 (13) | Rg: y1 | Resist: Df | Target suffers 1/3/4 damage. Ram Critical Strike: +1 per Ram.", "(1) Pine Box (Heavy Melee) | AV: 6 (14) | Rg: y2 or z9 | Resist: Df | Target suffers 2/3/4 damage. Crow Get in Box: Trap target, gains Boxed and Buried Condition."], "notes": "One of the few Guild Special Divisions genuinely appreciated by Malifaux citizens. Locate and eliminate Resurrectionists and undead."}}
{"_id":"hunter-construct","name":"Hunter","type":"fatemaster","system":{"rank":{"title":"Minion","value":6},"types":"Construct","aspects":{"might":3,"grace":2,"speed":3,"resilience":-1,"charm":-5,"cunning":-5,"intellect":-5,"tenacity":-5},"derived":{"defense":"4 (10)","willpower":"4 (10)","walk":"6","charge":"7","height":"2","initiative":"3 (9)"},"wounds":{"value":0,"max":7},"skills":{"centering":{"value":2},"pneumatic":{"value":3},"toughness":{"value":3},"track":{"value":1}},"abilities":[{"name":"Armor +1","description":"Reduce all damage suffered by 1 (minimum 1)."},{"name":"Pneumatic Tracker","description":"May substitute Pneumatic Skill for Cunning when using Notice and Track."},{"name":"Prey on the Unaware","description":"Attack flips gain + against characters that haven't taken a turn in Dramatic Time."}],"actions":["(1) Steel Claws (Pneumatic) | AV: 6 (12) | Rg: y1 | Resist: Df | Target suffers 2/4/5 damage. Ram Critical Strike: +1 per Ram. Mask Leap: Target Drop Prone.","(1) Chain Harpoon (Pneumatic) | AV: 5R (11R) | Rg: z10 | Resist: Df | Target suffers 2/3/5 and Slow. Ram Pull and Drag: Push 3 yards toward you."],"notes":"Construct designed to track escaped convicts. Segmented body, specially sprung legs, chain harpoon."}}
{"_id":"guardian-construct","name":"Guardian","type":"fatemaster","system":{"rank":{"title":"Minion","value":6},"types":"Construct","aspects":{"might":2,"grace":-1,"speed":2,"resilience":-1,"charm":-5,"cunning":-5,"intellect":-5,"tenacity":-5},"derived":{"defense":"5 (11)","willpower":"5 (11)","walk":"5","charge":"6","height":"2","initiative":"2 (8)"},"wounds":{"value":0,"max":8},"skills":{"centering":{"value":3},"evade":{"value":4},"labor":{"value":3},"toughness":{"value":4}},"abilities":[{"name":"Grinding Halt (Tome)","description":"Immediately gain Armor +2 for duration of this Action."},{"name":"Armor +1","description":"Reduce all damage suffered by 1 (minimum 1)."},{"name":"Relentless","description":"Immune to Horror Duels."}],"actions":["(1) Flatblade (Labor) | AV: 5 (11) | Rg: y3 | Resist: Df | Target suffers 2/3/4 damage.","(1) Shield (Labor) | AV: 5 (11) | Rg: y2 | Resist: Df | Target suffers 1/2/3 and push 1 yard. Mask Shield Bash: Enemies within p2 pushed 4 yards and gain Stunned.","(0) Protect | Target adjacent gains +2 Defense while in engagement range."],"notes":"Early construct designed to fight alongside human forces and shield them from harm."}}
{"_id":"riotbreaker","name":"Riotbreaker","type":"fatemaster","system":{"rank":{"title":"Minion","value":5},"types":"Construct","aspects":{"might":1,"grace":2,"speed":0,"resilience":1,"charm":-5,"cunning":-5,"intellect":-5,"tenacity":-5},"derived":{"defense":"1 (6)","willpower":"3 (8)","walk":"4","charge":"4","height":"2","initiative":"0 (5)"},"wounds":{"value":0,"max":9},"skills":{"centering":{"value":1},"labor":{"value":4},"shotgun":{"value":3},"toughness":{"value":4}},"abilities":[{"name":"Armor +1","description":"Reduce all damage suffered by 1 (minimum 1)."},{"name":"Hard to Wound +1","description":"Damage flips against this character suffer -."},{"name":"Pneumatic Entrenching Spikes","description":"Cannot move or be pushed except on its turn. Provides Hard Cover, cannot become Prone."}],"actions":["(1) Shield (Labor) | AV: 5 (10) | Rg: y2 | Resist: Df | Target suffers 1/2/3 damage. Push 1 yard. Ram Shield Slam: Target suffers 1 damage or becomes Prone.","(1) Riot Gun (Shotgun) | AV: 5 (10) | Rg: z10 | Resist: Df | Target suffers 2/3B/4BB damage. Characters gain Slow. Capacity 10, Reload 3."],"notes":"Guardian variant optimized for crowd control. Shotguns fire downward to ricochet (nonlethal levels). Anchored by pneumatic spikes."}}
{"_id":"exorcist","name":"Exorcist","type":"fatemaster","system":{"rank":{"title":"Enforcer","value":8},"types":"Living, Death Marshal","aspects":{"might":1,"grace":2,"speed":2,"resilience":1,"charm":-2,"cunning":3,"intellect":2,"tenacity":2},"derived":{"defense":"5 (13)","willpower":"6 (14)","walk":"5","charge":"6","height":"2","initiative":"4C (12C)"},"wounds":{"value":0,"max":7},"skills":{"archery":{"value":3},"centering":{"value":4},"counterSpelling":{"value":3},"evade":{"value":3},"history":{"value":2},"intimidation":{"value":3},"leadership":{"value":2},"literacy":{"value":1},"labor":{"value":3},"necromancy":{"value":2},"notice":{"value":2},"scrutiny":{"value":3},"toughness":{"value":2},"track":{"value":2}},"abilities":[{"name":"Hard to Wound +1","description":"Damage flips against this character suffer -."},{"name":"Relentless","description":"Immune to Horror Duels."},{"name":"Righteousness","description":"Undead and Spirit characters within a6 cannot declare Triggers."}],"actions":["(1) Crossbow Bayonet (Labor) | AV: 4 (12) | Rg: y1 | Resist: Df | Target suffers 1/3/4 damage. Ram Critical Strike: +1 per Ram.","(1) Sanctified Crossbow (Archery) | AV: 5 (13) | Rg: z10 | Resist: Df | Target suffers 2/4/6 damage. Ignores Incorporeal and Hard to Wound. Ram Critical Strike: +1 per Ram. Tome Pinned: Target gains Pinned to Ground Condition.","(0) It's A Zombie! (Notice) | AV: 5C (13C) | TN: 10C | Rg: 8 | Resist: Df | Target gains Undead Characteristic for 1 minute."],"notes":"Licensed freelance agent specializing in ghosts and evil spirits. Many are independent crusaders with personal vendettas against undead."}}
{"_id":"witchling-stalker","name":"Witchling Stalker","type":"fatemaster","system":{"rank":{"title":"Minion","value":6},"types":"Living, Witch Hunter, Witchling","aspects":{"might":3,"grace":2,"speed":2,"resilience":0,"charm":-1,"cunning":-1,"intellect":-1,"tenacity":2},"derived":{"defense":"5 (11)","willpower":"5 (11)","walk":"5","charge":"6","height":"2","initiative":"4 (10)"},"wounds":{"value":0,"max":6},"skills":{"athletics":{"value":1},"centering":{"value":3},"counterSpelling":{"value":3},"enchanting":{"value":1},"evade":{"value":3},"labor":{"value":3},"notice":{"value":2},"pistol":{"value":3},"toughness":{"value":2},"track":{"value":2}},"abilities":[{"name":"Drawn to Pain (Mask)","description":"After this character fails but before suffering damage, move distance equal to Walk speed directly toward attacker."},{"name":"Fiery Demise","description":"When killed, all characters within p2 suffer 1 damage and gain Burning +1."},{"name":"Searing Mark","description":"All characters damaged by this character gain Burning +1."},{"name":"Sense Magic","description":"When Spell cast within 30 yards, attempt Counter-Spelling Challenge (TN 20 - spell TN). On success, learn exact location and sense magical effects for duration."}],"actions":["(1) Shattered Rune Blade (Labor) | AV: 6 (12) | Rg: y1 | Resist: Df | Target suffers 2/3/5 damage. Crow Drain Magic: End magical effects and heal 1 Wound per effect.","(1) Runed Pistol (Pistol) | AV: 5 (11) | Rg: z12 | Resist: Df | Target suffers 2/3/4 damage. Capacity 6, Reload 2. Tome Cataclysm: Gains +B to Severe damage.","(1) Dispel Magic (Counter-Spelling) | AV: 5 (11) | TN: 10 | Rg: 12 | Resist: Wp | End all magical effects and Conditions from Spells/Manifested Powers."],"notes":"Rogue mages burned by Witch Hunter Sonnia Criid. Their magic turned against themselves, creating charred hunting dogs that sense and negate magic."}}
{"_id":"witchling-handler","name":"Witchling Handler","type":"fatemaster","system":{"rank":{"title":"Enforcer","value":8},"types":"Living, Witch Hunter","aspects":{"might":2,"grace":3,"speed":2,"resilience":2,"charm":-1,"cunning":0,"intellect":2,"tenacity":3},"derived":{"defense":"5R (13R)","willpower":"6R (14R)","walk":"5","charge":"6","height":"2","initiative":"5 (13)"},"wounds":{"value":0,"max":8},"skills":{"convince":{"value":2},"centering":{"value":4},"counterSpelling":{"value":3},"enchanting":{"value":3},"evade":{"value":3},"labor":{"value":4},"intimidation":{"value":2},"leadership":{"value":3},"notice":{"value":3},"pistol":{"value":3},"scrutiny":{"value":3},"sorcery":{"value":3},"toughness":{"value":3},"track":{"value":3}},"abilities":[{"name":"Reflect Magic (Ram+Mask)","description":"After succeeding against Spell/Manifested Power, attacker suffers 2/3B/5BB damage. Damage flip receives -."},{"name":"On My Orders (Ram)","description":"After succeeding, friendly Minion within 12 yards may take (1) Walk toward attacker. If Witchling, may make Close Combat attack."},{"name":"Thalarian Doctrine","description":"When casting Enchanting Spell/Manifested Power, two instances of Increased Duration Immuto added without increasing TN."}],"actions":["(1) Runed Greatsword (Labor) | AV: 6 (14) | Rg: y2 | Resist: Df | Target suffers 3/4/6 damage. Gains + if not part of Charge. Grants + to Intimidate. Crow Drain Magic: End magical effects and heal 1 Wound per effect.","(1) Burn Them All (Sorcery) | AV: 6T (14T) | TN: 14T | Rg: z10 | Resist: Wp | Target suffers 2/3B/4B damage. Every character damaged gains Burning +1.","(1) Collier Single Action Army (Pistol) | AV: 6 (14) | Rg: z12 | Resist: Df | Target suffers 2/3/4 damage. Capacity 6, Reload 2. Grants + to Intimidate."],"notes":"Trainers tasked with brainwashing Witchlings into living weapons after their personalities are burned away by Sonnia Criid."}}
{"_id":"guild-reporter","name":"Guild Reporter","type":"fatemaster","system":{"rank":{"title":"Minion","value":5},"types":"Living","aspects":{"might":-2,"grace":2,"speed":2,"resilience":-1,"charm":3,"cunning":2,"intellect":2,"tenacity":1},"derived":{"defense":"4 (9)","willpower":"4 (9)","walk":"7","charge":"—","height":"2","initiative":"5 (10)"},"wounds":{"value":0,"max":4},"skills":{"bewitch":{"value":2},"convince":{"value":1},"centering":{"value":2},"deceive":{"value":2},"forgery":{"value":2},"history":{"value":1},"literacy":{"value":3},"notice":{"value":3},"pickPocket":{"value":2},"scrutiny":{"value":2},"stealth":{"value":1},"bureaucracy":{"value":1}},"abilities":[{"name":"Better Part of Valor","description":"Walk increased by +2, but no Charge Aspect."},{"name":"Disguised","description":"Cannot be targeted by Charge Action."},{"name":"Distracting Presence","description":"Enemy characters within a5 ignore suit associations from Skills, cannot take Defensive Stance or Focus Actions."},{"name":"Don't Mind Me (11)","description":"If this character did not take offensive actions last turn, enemies must succeed TN 11 Scrutiny Challenge or choose different target."}],"actions":["(1) Incessant Questioning (Bewitch) | AV: 5 (10) | Rg: 5 | Resist: Wp | Target becomes Slow and Dazed until start of next turn.","(1) Flash Photography (Notice) | AV: 5 (10) | Rg: 5 | Resist: Wp | Target becomes Blind until start of next turn. Capacity 1, Reload 1. Ram Hey Look Over Here: Every character within p1 also becomes Blind."],"notes":"Guild-affiliated reporters gathering information unobtrusively. Work for Malifaux Daily Record or Malifaux Tattler newspapers."}}
