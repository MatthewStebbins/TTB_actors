{"_id":"G1DabbImbueProt0","name":"Imbue Protection","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 0","description":"Gains the following Tactical Action: (0) Imbue Protection: Target a friendly character within 1 yard (may be self) and discard a card. Target gains Condition for 5 minutes: \"Imbued Protection +N: When this character suffers damage, reduce damage by N (minimum 0), then reduce Condition value by the same amount.\" Card value 1-5: +1 | Card value 6-10: +2 | Card value 11+: +3."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbCntrMagic0","name":"Counter Magic","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 1","description":"Gains the following Tactical Action: (0) Counter Magic: Target a character within 10 yards and line of sight. Until the start of this character's next turn, the next time the target casts a Spell or Spell-like Manifested Power, this character may make a Counter-Spelling Challenge against a TN equal to the final duel total of that Spell/Power. Success: the Spell/Power is countered and has no effect."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbMastImmut0","name":"Mastered Immuto","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 1","description":"Choose an Immuto. This character always has access to it regardless of her current Grimoire. May be taken once per step that offers it (Steps 1, 5, and 9)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbArcaneMus0","name":"Arcane Musings","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 3","description":"This character adds +Tome to her Sorcery Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbMastMagia0","name":"Mastered Magia","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 3","description":"Choose a Magia. This character always has access to it regardless of her current Grimoire. If she has no Grimoire, she may act as if she had one containing this Magia. May be taken once per step that offers it (Steps 3 and 7)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbSpellTwist","name":"Spell Twisting","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 5","description":"After adding one or more Immuto to a Spell, this character may discard a card to add one additional instance of any Immuto she knows (may be the same Immuto if allowed) to the Spell with no increase to the Spell's TN."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbSurge00000","name":"Surge","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 7","description":"Gains the following Trigger on Magical Skill Challenges used to cast Spells: (Tome)(Tome) Surge: After succeeding, draw a card."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DabbEmpChanl00","name":"Empowered Channeling","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Dabbler","requirements":"Step 9","description":"This character gains a positive flip to the casting attempt and any resulting damage flip of the first Spell she casts on her turn."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
