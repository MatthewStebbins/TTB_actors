{"_id":"G1DrudHardWorkr0","name":"Hard Worker","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 0","description":"Gains a positive flip to all Athletics Challenges. If she succeeds on an Athletics Challenge, she gains a Margin of Success."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudKeepStand0","name":"Keep Standing","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 1","description":"May discard a Twist Card when suffering a Critical Effect: an Instant Critical Effect is ignored; a Lasting Critical Effect has no effect until the start of next turn (Dramatic Time) or 1 minute (Narrative Time). May also discard a Twist Card to automatically pass an Unconsciousness Challenge."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudLongSuffr0","name":"Long Suffering","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 1","description":"This character gains +2 Wounds."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudTeamwork00","name":"Teamwork","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 3","description":"May take the (1) Assist Action as a (0) Action. When targeted by the Assist Action, gains an additional positive flip to the assisted Action."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudHardToKll0","name":"Hard to Kill","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 3","description":"Once per Dramatic Time when this character receives a Critical Effect, she may choose not to receive it."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudSteadyPac0","name":"Steady Pace","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 5","description":"After succeeding at a Skill Challenge as part of an Ongoing Challenge, gains a positive flip to her next Skill Challenge in that same Ongoing Challenge."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudSlowToDie0","name":"Slow to Die","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 5","description":"When this character suffers a Critical Effect, the Critical Effect flip suffers a negative flip."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudSoldierOn0","name":"Soldier On","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 7","description":"At the beginning of Dramatic Time, this character may heal 2/3/5 damage. She may also choose one conscious friendly character that can hear her to also heal 2/3/5 damage."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudPutBackInt","name":"Put Your Back Into It","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 7","description":"Before performing a Close Combat, Expertise, Training, or Ranged Combat Skill Challenge, may discard a card to substitute Athletics + Resilience (if tied to a Physical Aspect) or Athletics + Tenacity (if tied to a Mental Aspect) in place of the original Skill and Aspect."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudJustGraze0","name":"Just a Graze","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 9","description":"This character may Cheat any Damage Flip she suffers, regardless of negative flip modifiers or Jokers."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudCantKeepDn","name":"Can't Keep Me Down","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 9","description":"At the start of this character's turn during Dramatic Time: if she has less than half her total Wounds remaining (rounded up), she heals 1 damage. If she is suffering from Critical Effect(s) or has less than 0 Wounds, she heals 2 damage instead."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1DrudMyLotLife0","name":"My Lot in Life","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Drudge","requirements":"Step 10","description":"At the start of this character's turn during Dramatic Time, may discard a card to gain additional AP equal to the number of Lasting Critical Effects she is suffering (even if ignoring them via Keep Standing). Maximum 3 additional AP."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravStrtBons01","name":"Graverobber Starting Bonus","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Starting Bonus","description":"A Grimoire containing 1 Necromancy Magia + 1 Enchanting/Prestidigitation/Sorcery Magia + 3 Immuto (total: 2 Magia, 3 Immuto)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravOnPursuit0","name":"Black Soul","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"On the Pursuit","description":"When this character fails a Magical duel during Dramatic Time, she may draw a card."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravSenseCorps","name":"Sense Corpses","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 0","description":"Gains the following Tactical Action: (0) Sense Corpse: This character may discard a card to sense the presence of a corpse within 5 yards of her. Corpses may be buried, hidden in walls, in containers, etc. This Action only locates corpses; it does not create them. The Fatemaster may declare no corpses are present in heavily patrolled areas (e.g., the Guild Enclave)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravTheyWrntU0","name":"They Weren't Using It","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 1","description":"When this character uses her Sense Corpse Talent, if the discarded card was a Crow (C), the corpse has valuables (rings, jewelry, pneumatic augmentations) worth half the value of the discarded card in scrip."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravMastImmut0","name":"Mastered Immuto","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 1","description":"Choose an Immuto. This character always has access to it regardless of her current Grimoire. May be taken once per step that offers it (Steps 1, 5, and 9)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravMorbidThts","name":"Morbid Thoughts","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 3","description":"This character adds +Crow to her Necromancy Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravMastMagia0","name":"Mastered Magia","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 3","description":"Choose a Magia. This character always has access to it regardless of her current Grimoire. If she has no Grimoire, she may act as if she had one containing this Magia. May be taken once per step that offers it (Steps 3 and 7)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravMacabreInf","name":"Macabre Infusions","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 5","description":"If this character does not have the Undead Characteristic, she may count as Undead whenever she wishes. Fatemaster Undead characters treat her with disinterest unless attacked or directly threatened."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravConsumCrps","name":"Consume Corpse","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 7","description":"When casting a Necromancy Spell, this character may consume any number of corpses within 5 yards of her to lower the Spell's TN by -2 per consumed corpse. Consumed corpses are reduced to dust and ash. No line of sight required (buried corpses sensed via Sense Corpses may be consumed). May also consume Undead subordinate characters under her direct control; uncontrolled undead or those under another character's control cannot be consumed."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravManiacLaff","name":"Maniacal Laugh","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 9","description":"This character may discard a card to animate all corpses within pulse 8 of her as Mindless Zombies (see NPC chapter). Zombies remain animated for a number of rounds equal to half the discarded card's value (rounded up). They count as subordinate characters under this character's control. This character may command every Mindless Zombie under her control with a (1) Order Action, and orders may be different."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G1GravUnholyBcn0","name":"Unholy Beacon","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Graverobber","requirements":"Step 10","description":"This character may discard a card from her Control Hand to take control of an Undead character within line of sight. Minion Rank or lower: No Challenge required; placed under this character's control as a subordinate indefinitely (until destroyed). Enforcer Rank or higher: Must succeed on a Necromancy + Charm Challenge opposed by the target's Willpower. Success: subordinate control for 24 hours. Failure: target is immune to this Talent for 24 hours. Stitched characters (Fated Undead) are immune to this Talent."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdStartBonus0","name":"Guard: Starting Bonus","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Starting Bonus","description":"One Close Combat weapon + any Armor (combined value <= 20 scrip)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdIronTank000","name":"Iron Tank","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"On the Pursuit","description":"On the Pursuit - Iron Tank: When this character fails a Close Combat duel during Dramatic Time, she may draw a card. Epilogue Skill Advancement: May advance any Close Combat Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdLastingChal","name":"Lasting Challenge","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 0","description":"When this character succeeds on the Impose Action, the effects last until the end of Dramatic Time or until this character takes the Impose Action again (in which case the previous Impose lasts until the start of this character's next turn)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdStoicDefndr","name":"Stoic Defender","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 1","description":"Gains the following Defensive Trigger: Df (R) Glancing Blow: When suffering damage, reduce the amount of damage suffered by 1, to a minimum of 0."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdStandGround","name":"Stand Ground","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 1","description":"This character does not need to discard a card to take the Defensive Stance Action."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdTakeTheHit0","name":"Take the Hit","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 3","description":"This character may discard a card from her Control Hand after an attack hits a friendly character within 2 yards of her. If she does, she moves to a position between the friendly character and the attacker and suffers the effects of the attack (which suffers a minus to its damage flip) instead of the friendly character. Opponents engaged with this character when she moves may not attempt Disengaging Strikes to stop this movement."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdOcularPtDwn","name":"Ocular Pat Down","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 3","description":"After watching a target character for at least 1 minute during Narrative Time, this character may attempt a Scrutiny Challenge (TN = target Cunning + Stealth + Rank Value). Failure: cannot use this Talent against the target for the remainder of the scene. Success: learns whether the target has concealed weapons and what they are. Target gains the Condition for the rest of the scene - Assessed Threat: This character suffers minus to Intimidate Challenges. If this character enters combat against the character that applied this Condition, this character's Initiative is reduced by -5 (minimum 0), and the character that applied this Condition gains plus to all Close Combat Attacks against this character."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdFlurry00000","name":"Flurry","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 5","description":"Choose a Close Combat Skill when gaining this Talent. Gains the following Tactical Action: (2) Flurry: This character may discard a Twist Card to take three 1 AP strikes with a Close Combat weapon using the chosen Skill against a single target."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdLaughOff000","name":"Laugh Off","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 5","description":"This character may not be pushed or moved by enemy characters."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdJuggernaut0","name":"Juggernaut","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 7","description":"Gains the following Tactical Action: (0) Juggernaut: This character may discard a card to heal 1/2/4 damage."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdImposingStc","name":"Imposing Stance","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 7","description":"When this character takes the Impose Action, she may target two characters instead of one. She makes a single Intimidate Challenge against both."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdEnduringDef","name":"Enduring Defense","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 9","description":"When this character takes the Defensive Stance action, her Defensive Condition lasts one additional round (i.e., until the start of her second turn after taking the action)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdKnockAside0","name":"Knock Aside","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 9","description":"Gains the following Defensive Trigger: Df (M) Knock Aside: After an attacker misses this character with a Close Combat attack, if this character has a readied Close Combat weapon, the attacker suffers that weapon's weak damage and is pushed a number of yards away equal to this character's Might Aspect (minimum 1 yard)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GrdSentinel000","name":"Sentinel","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Guard","requirements":"Step 10","description":"This character may take the Defensive Stance Action as a (0) Action. Whenever this character has the Defensive Condition (at any value), all friendly characters within 2 yards gain plus to their Defense Challenges."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunStartBonus0","name":"Gunfighter: Starting Bonus","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Starting Bonus","description":"One or two Pistols (combined value <= 20 scrip)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunHighNoon000","name":"High Noon","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"On the Pursuit","description":"On the Pursuit - High Noon: When this character fails a Ranged Combat duel during Dramatic Time, she may draw a card. Epilogue Skill Advancement: May advance any Ranged Combat Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunQuickDraw00","name":"Quick Draw","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 0","description":"This character may treat the (1) Ready Weapon Action as a (0) Action when drawing a Pistol, and she may draw two Pistols instead of one."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunCallOut0000","name":"Call Out","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 1","description":"When this character takes the Impose Action, she may add her ranks in the Pistol Skill to her final duel total."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunBulletproof","name":"Bulletproof","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 1","description":"Bulletproof +1: Reduce all damage suffered from Ranged Combat attacks by 1, to a minimum of 1."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunGunfighter0","name":"Gunfighter","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 3","description":"This character may use Pistol weapons as if their Range were melee 2 (in addition to their normal range). This allows firing in melee without penalty."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunQuickReload","name":"Quick Reload","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 3","description":"This character reduces the AP cost to load Pistol weapons by 1."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunRapidFire00","name":"Rapid Fire","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 5","description":"Gains the following Tactical Action: (2) Rapid Fire: This character may discard a Twist Card to take three 1 AP Ranged Combat attacks with a Ranged Combat weapon against a single target."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunFastestGun0","name":"Fastest Gun","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 5","description":"Gains the following Defensive Trigger: Df (M) Fastest Gun: After a Ranged Combat attack fails against this character, this character may expend one round of ammunition in a readied Pistol to deal its damage to the attacker. This damage flip receives a minus."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunNoTimeForTs","name":"No Time For This","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 7","description":"Whenever this character is involved in an Ongoing Challenge, she may choose to make one of the Challenge Flips using her Pistol Skill instead of the appropriate Skill (she still uses the appropriate Aspect). The Fatemaster and player determine how this works narratively."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunDebltngShot","name":"Debilitating Shot","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 7","description":"After damaging an enemy with a Ranged Combat weapon, this character may discard a card to give that enemy the Useless Limb (Arms) or Useless Limb (Legs) Condition (her choice). The Condition lasts until the enemy has fully healed all missing Wounds."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunFngOnTrggr0","name":"Finger on the Trigger","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 9","description":"Gains the following Tactical Action: (1) Finger on the Trigger: Until the start of this character's next turn, if an enemy character within 10 yards declares a Charge Action or Ranged Combat action, this character may immediately make a 1 AP Ranged Combat attack against that enemy. On a success, the enemy suffers 1 damage and the Charge/Ranged Combat action fails."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunBulltBndng0","name":"Bullet Bending","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 9","description":"Before making a Ranged Combat attack, this character may discard a card. If she does, her attack may ignore either cover or line of sight (her choice). If she ignores line of sight and fires at a target behind cover, that target still receives cover benefits as normal."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2GunRangedExprt","name":"Ranged Expert","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Gunfighter","requirements":"Step 10","description":"This character gains 1 additional AP on her turn, but this AP may only be used to make a Ranged Combat attack."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcStartBonus0","name":"Mercenary: Starting Bonus","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Starting Bonus","description":"One Ranged Combat weapon + any Armor (combined value <= 20 scrip)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcFistfulScrp","name":"A Fistful of Scrip","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"On the Pursuit","description":"On the Pursuit - A Fistful of Scrip: When this character fails a Ranged Combat duel during Dramatic Time, she may draw a card. Epilogue Skill Advancement: May advance any Ranged Combat Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcBountyHuntr","name":"Bounty Hunter","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 0","description":"When this character encounters a character with a bounty on their head, she automatically recognizes this and remembers the bounty amount and whether they are wanted dead, alive, or either. If the wanted character is disguised or using a fake name, this character must succeed on a Scrutiny Challenge (TN = target Deceive + Cunning + Rank Value) to see through it; failure means the disguise prevents recognition."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcEndlessPrst","name":"Endless Pursuit","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 1","description":"Gains plus to Track Challenges. On a successful Track Challenge, finds her target 50% faster than normal. On a Margin of Success, learns how tracked characters are equipped (provisions, weapons, armor, general ammunition level)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcOddJobs0000","name":"Odd Jobs","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 1","description":"At the start of every session, this character gains scrip equal to twice her completed ranks in this Pursuit. Requires at least 8 hours of waking time between sessions to have completed odd jobs. Exact nature determined with the Fatemaster."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcToHghstBddr","name":"To the Highest Bidder","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 3","description":"When targeted with a Close Combat attack by a non-Beast attacker, this character may throw scrip amounting to no less than half the attacker's Rank Value into the air. If she does, she may add her ranks in Barter to her Defense and Willpower for the duration of the attack. If the attack misses, the attacker cannot make further attacks against this character for the rest of its turn. If the attack achieves a Margin of Failure, the attacker's turn immediately ends as it chases the money."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcCntrtNgtn00","name":"Contract Negotiation","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 3","description":"Gains plus to Barter Challenges. When turning in a bounty (dead or alive), may attempt a Barter Challenge (TN = 5 + target Rank Value) to increase the bounty value by +50%."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcHumanShield","name":"Human Shield","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 5","description":"Gains the following Defensive Trigger: Df (M) Human Shield: After this character fails, she grabs a target character of Minion rank or lower within 2 yards and Line of Sight (not the attacker) and places it between herself and the attacker. Damage is split evenly between the Minion and this character, with any uneven damage going to the Minion."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcMakingEnds0","name":"Making Ends Meet","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 5","description":"After this character fails a Skill Challenge, she may lose scrip equal to twice the difference between her final acting value and the Challenge TN. If she does, she is considered to have passed the Challenge with no Margins of Success. If it was an attack, it counts as a tie (damage flip suffers a minus-minus modifier)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcCoinForKils","name":"Coin for Kills","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 7","description":"After this character kills an enemy, she may discard a card to gain scrip equal to the target's Rank Value. Source (loot, eerie winds blowing scrip bills, etc.) determined by player and Fatemaster."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcDeadlyHuntr","name":"Deadly Hunter","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 7","description":"This character gains plus to the damage flip of any attack against a target she was paid to fight or kill (including bounties). Fatemaster determines what qualifies."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcHardKnockLf","name":"Hard Knock Life","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 9","description":"At the end of her turn during Dramatic Time, this character may choose to either lose 2 scrip or suffer 1 Wound. If she chooses either, she may draw a card."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcBorrowdTime","name":"Borrowed Time","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 9","description":"At the start of her turn during Dramatic Time, this character may choose to lose 5 scrip or suffer 2 damage. If she chooses either, she gains Fast."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2MrcPaidInAdvnc","name":"Paid in Advance","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Mercenary","requirements":"Step 10","description":"When flipping Initiative at the start of Dramatic Time, this character may draw up to 5 cards. If she does, at the start of her second turn and every turn thereafter until end of Dramatic Time, she must discard a card (if possible). When accepting a mission or bounty, she gains 50% of the final reward as an advance. If she fails to complete it and does not return the advance, her reputation suffers, she earns enemies, and she cannot use this Talent for 2 months."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrStartBonus0","name":"Overseer: Starting Bonus","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Starting Bonus","description":"Non-magical skill toolkit."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrOversight00","name":"Oversight","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"On the Pursuit","description":"On the Pursuit - Oversight: When this character fails a Social duel, she may draw a card. Epilogue Skill Advancement: May advance any Social Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrMgmtMtrl000","name":"Management Material","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 0","description":"When this character joins an Ongoing Challenge, she may discard a card to use the Leadership Skill as if it were one of the Skills Allowed by the Ongoing Challenge for a set number of Durations based on the discarded card's value: Value 1-5: 1 Duration. Value 6-10: 2 Durations. Value 11+: 3 Durations."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrCncrtdEffrt","name":"Concerted Effort","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 1","description":"This character always makes Initiative flips before any of her companions. If multiple characters have this Talent, they choose their order among themselves. Friendly characters making Initiative flips may choose not to flip and instead use this character's initiative value (after all modifiers)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrSupervision","name":"Supervision","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 1","description":"This character may discard a card to add the suit of the discarded card to the final duel total of any friendly character that can see or hear her (including herself)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrWorkSmarter","name":"Work Smarter","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 3","description":"After this character succeeds at a Skill Challenge during an Ongoing Challenge, permanently reduce the Ongoing Challenge's TN by -1 for all subsequent Durations. Cumulative if multiple characters have this Talent."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrRmndrWrsFte","name":"Reminder of a Worse Fate","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 3","description":"When another friendly character within 6 yards attempts a Horror or Unconsciousness Challenge, she may add this character's ranks in Leadership to her final duel total."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrBestPractcs","name":"Best Practices","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 5","description":"When this character succeeds on a Challenge Flip made as part of an Ongoing Challenge, she gains one extra Margin of Success."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrProtectMe00","name":"Protect Me!","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 5","description":"Gains the following Defensive Trigger: Df (t) Protect Me!: After this character fails, another willing character within 2 yards (within range and line of sight of the attacker) suffers the effects of the attack instead of this character. This character's subordinate characters are always considered willing."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrHowToDoJob0","name":"How to Do Your Job","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 7","description":"After another character within 6 yards fails a Skill Challenge, this character may discard a card to make a Skill Challenge against the same TN (with the same flip modifiers). If this character succeeds, the other character uses this character's final duel total in place of her failed total."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrYouLazySnSo","name":"You Lazy So-and-So","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 7","description":"Gains the following Manifested Power - You Lazy So-and-So: Charm + Leadership, 1 AP, TN 8R, Resist Wp, Range 6 yards. Effect: Target unconscious character regains consciousness and heals 1/2/3 damage. Trigger R Stop Complaining: The target may ignore one Critical Effect currently affecting her for 3 rounds. Trigger t On Your Feet!: The target may immediately stand up from being Prone."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrFinishJob00","name":"Finish the Job","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 9","description":"When another friendly character within 6 yards would fall unconscious or be killed, that character may discard a card to take a 1 AP Action before falling unconscious or being killed. Cannot affect a specific character more than once per round."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrStayFocusd0","name":"Stay Focused","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 9","description":"This character may discard a card to end the Focused Condition on herself. If she does, every friendly character within 6 yards that can see or hear her gains Focused +1."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2OvrWhatLackeys","name":"What Lackeys Are For","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Overseer","requirements":"Step 10","description":"On her turn during Dramatic Time, this character may discard three cards. If she does, every friendly character that can see or hear her may immediately take a 1 AP Action in any order this character wishes."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfStartBonus0","name":"Performer: Starting Bonus","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Starting Bonus","description":"Non-magical skill toolkit."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfFlairDrmatc","name":"Flair for the Dramatic","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"On the Pursuit","description":"On the Pursuit - Flair for the Dramatic: When this character fails a Social duel, she may draw a card. Epilogue Skill Advancement: May advance any Social Skill."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfCntrAttnt00","name":"Center of Attention","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 0","description":"After another character fails a Social Skill Challenge, this character may discard a card to make a Skill Challenge with the same Skill against the same TN (with the same flip modifiers). If she succeeds, this character is considered to have succeeded on the initial Social duel and the original character's failure is ignored."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfDistrctnPrf","name":"Distracting Performance","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 1","description":"When this character is performing in any manner, her allies within 10 yards gain plus to their Deceive, Pick Pocket, and Stealth Challenges for the duration of the performance."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfGraceUnFire","name":"Grace Under Fire","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 3","description":"This character may substitute her Grace for her Speed when calculating her Defense Aspect and when flipping for Initiative."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfPwrflImprsn","name":"Powerful Impression","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 3","description":"Gains the following Trigger on all Social duels: M Impress: After succeeding, draw a card."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfHelluvaEntr","name":"Helluva Entrance","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 5","description":"This character may gain plus to the first non-Stealth Challenge Flip she makes in any scene. If she does, she suffers minus to all Stealth Challenges she makes for the remainder of that scene."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfChrmngDmnr0","name":"Charming Demeanor","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 5","description":"When this character is targeted with an attack, she may discard a card to impose a minus-minus penalty to the attack flip."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfOpeningAct0","name":"Opening Act","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 7","description":"After flipping for Initiative at the start of Dramatic Time, this character may nominate a friendly character (which may be herself) to take a Walk Action."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfWrldIsStage","name":"The World is a Stage","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 7","description":"When this character is involved in an Ongoing Challenge, she may choose to make one of the Challenge Flips using her Bewitch or Music Skill instead of the appropriate Skill (she still uses the appropriate Aspect). The Fatemaster and player explain how this works narratively."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfWhsprInYrEr","name":"A Whisper in Your Ear","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 9","description":"If this character scores a Margin of Success on a Bewitch Challenge during Narrative Time, she may force the target to perform a single act of up to one hour in length. Unless she achieves two Margins of Success, the act cannot involve violence. For the duration, the target believes the act was their own idea (though they may come to doubt this later). This action cannot cause the target to directly hurt themselves."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfPractcdPrdn","name":"Practiced Production","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 9","description":"If this character achieves a Margin of Success on a Skill Challenge, she may choose not to apply it to her own result. If she does so, she may instead apply that Margin of Success to a successful Skill Challenge made by one of her allies, provided her ally makes the Skill Challenge within five minutes of her own. The maximum number of Margins of Success she may have saved at one time cannot exceed her Charm Aspect (minimum one)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G2PrfThatsShowbz","name":"That's Showbiz","type":"talent","img":"icons/magic/symbols/runes-star-purple.webp","system":{"pursuit":"Performer","requirements":"Step 10","description":"This character may exchange her Charm Aspect for any of her other Mental Aspects when she makes a Social Skill Challenge."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioStartBonus1", "name": "Pioneer - Starting Bonus", "system": {"pursuit": "Pioneer", "requirements": "Starting Bonus", "description": "Non-magical skill toolkit."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioOnPursuit01", "name": "Rugged Individual", "system": {"pursuit": "Pioneer", "requirements": "On the Pursuit", "description": "When this character fails a Training duel, she may draw a card."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioUnimpeded01", "name": "Unimpeded", "system": {"pursuit": "Pioneer", "requirements": "Step 0", "description": "This character ignores penalties for severe terrain while taking Movement Actions."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioMakingDo001", "name": "Making Do With What We Have", "system": {"pursuit": "Pioneer", "requirements": "Step 1", "description": "This character may discard a card to create a skill toolkit for a skill she has at least 1 rank in. Unless the discarded card had a value of 11+, only this character may use the toolkit. The toolkit lasts for one hour."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioCircleWag01", "name": "Circle the Wagons", "system": {"pursuit": "Pioneer", "requirements": "Step 3", "description": "On her turn during Dramatic Time, this character may discard a card to let all friendly characters that can hear her treat Severe Terrain as if it were also Soft Cover, or Soft Cover as if it were Hard Cover. This effect lasts until the end of Dramatic Time."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioAtaGlance01", "name": "At a Glance", "system": {"pursuit": "Pioneer", "requirements": "Step 3", "description": "If this character fails a Notice Challenge, she may discard a card to reflip the Notice Challenge with a +."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioHealPoult01", "name": "Healing Poultices", "system": {"pursuit": "Pioneer", "requirements": "Step 5", "description": "When in a rural or wilderness area, this character may spend one hour and discard a card to produce Healing Poultices: card value 1-5 produces 1 poultice; card value 6-10 produces 2 poultices; card value 11+ produces 3 poultices. Any character may apply a Healing Poultice to a Living character as a (2) AP Action, reducing the target's Poison Condition value by 5 (minimum 0) and healing 2/3/4 damage. Poultices remain viable for 3 days before decaying."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioFavorTerr01", "name": "Favorable Terrain", "system": {"pursuit": "Pioneer", "requirements": "Step 5", "description": "At the start of Dramatic Time, this character may discard a card to declare that one patch of ground no more than 3 yards in radius counts as Severe Terrain. How it came to be so is determined by the player and Fatemaster. The area remains Severe Terrain indefinitely until physically altered."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioSurvivali01", "name": "Survivalist", "system": {"pursuit": "Pioneer", "requirements": "Step 7", "description": "This character no longer suffers damage from Hazardous Terrain. She and any allies she travels with gain + on any Challenges made to resist the elements or other environmental hazards (frostbite, sunstroke, biting insects, drowning, etc.)."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioKnowPath001", "name": "Know the Path", "system": {"pursuit": "Pioneer", "requirements": "Step 7", "description": "When this character joins an Ongoing Challenge that allows the use of Homesteading, Track, or Wilderness Skills, the TN of the Ongoing Challenge is lowered by -2 for participating characters that use one of those Skills."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioPathfinde01", "name": "Pathfinder", "system": {"pursuit": "Pioneer", "requirements": "Step 9", "description": "Friendly characters within aura 3 of this character ignore movement penalties for terrain while taking Movement Actions, and only suffer 1 damage from Hazardous Terrain (instead of full damage)."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioNatureLov01", "name": "Nature Lover", "system": {"pursuit": "Pioneer", "requirements": "Step 9", "description": "At the start of this character's turn during Dramatic Time, if she is in Severe or Hazardous Terrain, she may draw a card and then discard a card."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3PioManifDest01", "name": "Manifest Destiny", "system": {"pursuit": "Pioneer", "requirements": "Step 10", "description": "This character may discard two cards to lay claim to a reasonably sized area (generally one structure or natural area such as a grove). This grants no immediate legal ownership, but gives + to Bureaucracy, Convince, or Intimidate Challenges to assert her claim. This bonus lasts until she uses this Talent again. While on any land reasonably considered to be owned by this character (her homestead, claimed Contract Town, or an area claimed with this Talent), she generates 1 additional General AP at the start of her turn."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpStartBonus1", "name": "Scrapper - Starting Bonus", "system": {"pursuit": "Scrapper", "requirements": "Starting Bonus", "description": "One Close Combat weapon + any Armor (combined value <= 20 scrip)."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpOnPursuit01", "name": "Bloody Minded", "system": {"pursuit": "Scrapper", "requirements": "On the Pursuit", "description": "When this character fails a Close Combat duel during Dramatic Time, she may draw a card."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpIntoFray001", "name": "Into the Fray", "system": {"pursuit": "Scrapper", "requirements": "Step 0", "description": "This character increases her Charge Aspect by +2."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpDuckWeave01", "name": "Duck and Weave", "system": {"pursuit": "Scrapper", "requirements": "Step 1", "description": "Gains the following Trigger on Close Combat attacks - Tome (Duck and Weave): After succeeding, this character increases her Defense by +1 until the start of her next turn."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpFastHeale01", "name": "Fast Healer", "system": {"pursuit": "Scrapper", "requirements": "Step 1", "description": "Gains + to Healing Flips. When healed with the Artefacting, Doctor, or Stitching Skills, heals one additional damage."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpCloseGap001", "name": "Close the Gap", "system": {"pursuit": "Scrapper", "requirements": "Step 3", "description": "When this character declares a Charge Action, she may draw a Twist Card."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpShootPast01", "name": "Shoot Past Me", "system": {"pursuit": "Scrapper", "requirements": "Step 3", "description": "Friendly characters do not flip a card for this character when shooting into an engagement she is involved in."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpWicked00001", "name": "Wicked", "system": {"pursuit": "Scrapper", "requirements": "Step 5", "description": "When this character makes a successful disengaging strike, she deals damage with her weapon in addition to stopping her target's movement."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpFlurry00001", "name": "Flurry", "system": {"pursuit": "Scrapper", "requirements": "Step 5", "description": "Choose a Close Combat Skill when gaining this Talent. Gains the following Tactical Action - (2) Flurry: This character may discard a Twist Card to take three 1 AP strikes with a Close Combat weapon using the chosen Skill against a single target."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpFinishCur01", "name": "Finish the Cur", "system": {"pursuit": "Scrapper", "requirements": "Step 7", "description": "Once per round, after an enemy character suffers a Critical Effect, this character may discard a card to allow a friendly character within 5 yards of her (which may be herself) to make a 1 AP Close Combat attack against that enemy character."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpCntrCharg01", "name": "Counter-Charge", "system": {"pursuit": "Scrapper", "requirements": "Step 7", "description": "Once per round, after an enemy character completes a Charge Action against this character (including any resulting attacks), this character may discard a card to make a Close Combat attack against that enemy character."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpDivingChr01", "name": "Diving Charge", "system": {"pursuit": "Scrapper", "requirements": "Step 9", "description": "This character may declare Charge Actions while she is engaged. When moving as part of a Charge Action, she may ignore intervening characters, is not slowed by terrain, and opponents engaged with her may not attempt Disengaging Strikes to prevent her movement."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpMomentum001", "name": "Momentum", "system": {"pursuit": "Scrapper", "requirements": "Step 9", "description": "After this character completes the movement portion of a Charge Action, she may make a single Athletics Challenge opposed by the Evade Challenges of every character within her engagement range. Every character that fails this Evade Challenge suffers 1 damage and immediately becomes Prone."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3ScpMeleeExpt01", "name": "Melee Expert", "system": {"pursuit": "Scrapper", "requirements": "Step 10", "description": "This character gains 1 additional AP on her turn, but this AP may only be used to make a Close Combat attack."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkStartBonus1", "name": "Tinkerer - Starting Bonus", "system": {"pursuit": "Tinkerer", "requirements": "Starting Bonus", "description": "One Height 1 Construct built per construct creation rules (25 scrip total value)."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkOnPursuit01", "name": "Gear Head", "system": {"pursuit": "Tinkerer", "requirements": "On the Pursuit", "description": "When one of this character's subordinate Constructs fails a Pneumatic duel during Dramatic Time, this character may draw a card."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkMachMagic01", "name": "Machine Magic", "system": {"pursuit": "Tinkerer", "requirements": "Step 0", "description": "This character always has access to the Animate Construct Magia, no matter her current Grimoire. If she does not possess a Grimoire, she may act as if she possessed a Grimoire with this Magia. If she does not possess a Magical Theory, she gains the Darlin Theories Magical Theory."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkLoyalProt01", "name": "Loyal Protector", "system": {"pursuit": "Tinkerer", "requirements": "Step 1", "description": "While this character is within 2 yards of one or more of her subordinate Constructs, she may add the Height of the largest such Construct to her Defense."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkCnstrSpec01", "name": "Construct Specialist", "system": {"pursuit": "Tinkerer", "requirements": "Step 3", "description": "When this character gains this Talent, she chooses one Skill. With an hour of work, this character may increase a Construct's ranks in that Skill to a value equal to her ranks in the Engineering Skill. When this character builds a Construct, it gains a number of ranks of the chosen Skill equal to her ranks in Engineering at no additional cost."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkPushLimit01", "name": "Push the Limits", "system": {"pursuit": "Tinkerer", "requirements": "Step 3", "description": "When a subordinate Construct under this character's control performs an Action, this character can force it to suffer 1 damage. If she does so, the Construct gains + on the Action. If this character is a Construct or has at least one pneumatic limb, she may use this Talent on herself."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkMendSteel01", "name": "Mend Steel", "system": {"pursuit": "Tinkerer", "requirements": "Step 5", "description": "When this character successfully casts the Animate Construct Magia on a Construct, the Construct heals 1/2/3 damage. If this character is a Construct, she may cast the Animate Construct Magia on herself to heal her own damage in this way."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkMultiTask01", "name": "Multi-Tasker", "system": {"pursuit": "Tinkerer", "requirements": "Step 5", "description": "When this character takes a (1) Order Action, she may give orders to an additional Construct subordinate, and the orders for each Construct may be different."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkUnrealExp01", "name": "Unrealistic Expectations", "system": {"pursuit": "Tinkerer", "requirements": "Step 7", "description": "With an hour of tinkering, this character can give a subordinate Construct character a +1 increase to one of its Physical Aspects for one week. Subordinate characters who are not Constructs can benefit from this Talent as well, provided that they have one or more pneumatic limbs. A character can only benefit from a single instance of this Talent at one time; any additional applications merely change which Aspect is increased and reset the duration."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkBldgEdgTc01", "name": "Bleeding Edge Tech", "system": {"pursuit": "Tinkerer", "requirements": "Step 7", "description": "When this character is building a Construct, each Construct Point she spends to increase its Skills gives the Construct twice as many Skill Ranks to distribute as normal."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkOverPress01", "name": "Over Pressure", "system": {"pursuit": "Tinkerer", "requirements": "Step 9", "description": "This character and every subordinate Construct under her control gains the following Trigger on their Pneumatic attacks - Tome (Over Pressure): After succeeding, take an additional attack against the target. This Trigger may only be declared once per turn. If this character is a Construct or has at least one pneumatic limb, she also gains this Trigger on her Pugilism and Martial Arts attacks."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkMagicMant01", "name": "Magical Maintenance", "system": {"pursuit": "Tinkerer", "requirements": "Step 9", "description": "At the start of this character's turn, each of her subordinate Constructs within aura 4 heals 1 damage."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3TnkRiseMachi01", "name": "Rise of the Machines", "system": {"pursuit": "Tinkerer", "requirements": "Step 10", "description": "When this character takes the (1) Order Action to command a subordinate Construct during Dramatic Time, it may act normally at the end of her next turn as well as the current turn, just as if she had taken the (1) Order Action on her next turn to command it. If this character is killed or knocked unconscious before then, the Construct still gets its free turn immediately after when this character's turn would normally have been."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstStartBonus1", "name": "Wastrel - Starting Bonus", "system": {"pursuit": "Wastrel", "requirements": "Starting Bonus", "description": "Non-magical skill toolkit."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstOnPursuit01", "name": "Aces and Eights", "system": {"pursuit": "Wastrel", "requirements": "On the Pursuit", "description": "When this character fails an Expertise duel, she may draw a card."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstLuckDraw001", "name": "Luck of the Draw", "system": {"pursuit": "Wastrel", "requirements": "Step 0", "description": "When the Fate Deck is shuffled, this character draws two cards instead of one."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstCardsSlev01", "name": "Cards Up a Sleeve", "system": {"pursuit": "Wastrel", "requirements": "Step 1", "description": "At any point, this character may place one Twist Card from her Control Hand face up on the table in front of her. While the Twist Card is face up, any player may discard a card from their Control Hand to Cheat Fate with that card instead of a card from their own Control Hand. After the face up card has been used to Cheat Fate, or at the end of the session, it is discarded into the appropriate discard pile. This character may only have one face up Twist Card in front of her at any one time."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstMarkCards01", "name": "Marked Cards", "system": {"pursuit": "Wastrel", "requirements": "Step 3", "description": "At any point during this character's turn during Dramatic Time, she may discard a card to look at the top three cards of the Fate Deck and either discard all three cards or replace all three cards in any order."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstDoubleDown1", "name": "Double Down", "system": {"pursuit": "Wastrel", "requirements": "Step 3 or Step 7", "description": "After succeeding at a Challenge, this character may choose to Double Down. If she does, she makes a second Challenge using all the same modifiers as the first. If this second Challenge succeeds, it has no effect other than allowing her to either deal +1 damage to her target (if the Challenge was an attack) or gain a Margin of Success (if the Challenge was not an attack). If the second Skill Challenge fails, her original success counts as a failure. If this Talent is gained a second time (Step 7), when this character would be able to declare a legal Trigger on her second Challenge, she may choose to declare that Trigger in addition to any she declared on her first Challenge. This can allow the character to potentially declare two Triggers on a single Action (one from the initial flip and one from the second flip), provided both Triggers are different. The character may choose the order in which the Triggers resolve."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstAllIn000001", "name": "All In", "system": {"pursuit": "Wastrel", "requirements": "Step 5", "description": "This character gains + to all duels when she has no Twist Cards in her hand."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstCntCards001", "name": "Counting Cards", "system": {"pursuit": "Wastrel", "requirements": "Step 5", "description": "At the start of this character's turn, she may discard a Twist Card. If she does, for the rest of her turn, this character flips cards from the top of the Fate Deck discard pile instead of from the Fate Deck. While this Talent is being used, any Fate Card that would be discarded is instead set aside and discarded at the end of this character's turn. If this character cannot flip a card from the discard pile (if it has run out of cards), then any cards she cannot flip are treated as if she had instead flipped the Black Joker."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstGamblLife01", "name": "Gamble Your Life", "system": {"pursuit": "Wastrel", "requirements": "Step 7", "description": "Gains the following Manifested Power - Gamble Your Life: (1) AP, TN 10 Mask, Skill Cunning + Gambling vs target's Gambling + Cunning, Range 6 yards. Effect: The target suffers 3/4/6 damage. If the target successfully resists this Manifested Power, the caster suffers 3/4/6 damage. Damage flips generated by this Manifested Power may not be Cheated and ignore all + and - modifiers."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstHighAces001", "name": "High Aces", "system": {"pursuit": "Wastrel", "requirements": "Step 9", "description": "This character may treat all Ace cards in the Fate Deck and her Control Hand as if they had either a value of 1 or 11. She must make this choice immediately after the Ace card is flipped or cheated."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstMulligan001", "name": "Mulligan", "system": {"pursuit": "Wastrel", "requirements": "Step 9", "description": "Once per session, this character may discard her Control Hand, shuffle her discard pile into her Twist Deck, and draw three cards. If the character discarded at least one Twist Card in this way, she may also shuffle the Fate discard pile into the Fate Deck (which in turn allows all of the Fated to draw a card due to the Fate Deck being reshuffled)."}}
{"type": "talent", "img": "icons/magic/symbols/runes-star-purple.webp", "effects": [], "folder": null, "sort": 0, "ownership": {}, "flags": {}, "_id": "G3WstFiftyFifty1", "name": "Fifty-Fifty Chance", "system": {"pursuit": "Wastrel", "requirements": "Step 10", "description": "Once per Dramatic Time, instead of flipping a card from the Fate Deck, this character may stack the deck by going through the Fate Deck and discard pile to find both Jokers. The Fatemaster then randomly chooses one of the Jokers without looking at them and shuffles it into the Fate Deck. The remaining Joker is then placed on top of the Fate Deck for the character to flip over."}}
{"_id":"G4DM1SpecialDis1","name":"Special Dispensation","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Death Marshal","requirements":"Step 1","description":"This character gains special permission from the Guild to use necromantic magic, so long as it does not result in the creation of Undead creatures. This character always has access to the Subsume Corpse Magia, no matter her current Grimoire. If she does not possess a Grimoire, she may act as if she possessed a Grimoire with this Magia. If the character does not have a Magical Theory, she gains the Thalarian Doctrine Magical Theory. This character's special training allows her to have more than 2 ranks in the Necromancy Skill without violating the Thalarian Doctrine. The character is also issued a Peacebringer."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4DM2FearNotDe01","name":"Fear Not Death","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Death Marshal","requirements":"Step 2","description":"This character's corpse can never be reanimated as an Undead creature; every attempt to do so automatically fails. When this character kills another character, she may choose to instantly render her target's remains unfit to be reanimated into an Undead creature. In addition, this character gains the ability Hard to Wound +1: Damage flips against this character suffer -."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4DM3PineBox0001","name":"Pine Box","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Death Marshal","requirements":"Step 3","description":"The character may carry her coffin without any undue difficulty, though its actual weight does not change. When used in this way, the coffin is a Heavy Melee weapon (Pine Box, melee 2, Damage 2/3/4). Special: Thrown. When carried, this weapon is always considered to be readied. Trigger — C Get In The Box: After succeeding, the target is trapped in the Pine Box and gains the Condition \"Boxed and Buried: This character is removed from reality and cannot take Actions\" until this character (or another character, if this character is killed) takes a (1) Action to open it. This Trigger may not be declared if there is already a character in the Pine Box. If her coffin is destroyed, the character may replace it with a day of work."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4DM4OneFtGrav01","name":"One Foot in the Grave","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Death Marshal","requirements":"Step 4","description":"If this character is in physical contact with her coffin, she heals 1 damage at the start of each of her turns during Dramatic Time."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4DM5FlamesPit01","name":"Flames of the Pit","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Death Marshal","requirements":"Step 5","description":"Once per session as a (0) Action, the character can draw upon her necromantic powers to make her flesh temporarily fall away, revealing bare bones that blaze with phantom flames. While in this state: This character suffers - to all Social Skill Challenges other than Intimidate, which gains +. If an Undead character ends a Walk Action within this character's engagement range or targets her with an Action, it must attempt a TN 12 Horror Duel. This effect lasts until the character takes another (0) Action to end the effect, or until the end of the session."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4FK1Outfitting1","name":"Outfitting","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Freikorpsmann","requirements":"Step 1","description":"Upon joining, the character is issued standard gear: a Clockwork Pistol, a Hunting Knife, and a full suit of Clockwork Armor. Damaged or lost issued items may be repurchased from the Freikorps at 50% of market value. Clockwork Armor components: Clockwork Body (Light, Protected (R), Sealed, 17§, Skill 2); Clockwork Head (Light, Protected (t), Sealed, 12§, Skill 2); Clockwork Arms (Protected (C), Sealed, 14§, Skill 2); Clockwork Legs (Protected (M), Sealed, 14§, Skill 2). Sealed: A character wearing Sealed armor on her head, chest, legs, and arms ignores all damage from poison and blast effects."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4FK1PowderWar01","name":"Powder Wars Training","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Freikorpsmann","requirements":"Step 1","description":"When making a non-Magical Skill Challenge, this character may discard a card to add the suit of the discarded card to her final duel total."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4FK2SurvivalTr1","name":"Survival Training","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Freikorpsmann","requirements":"Step 2","description":"Reduces the Defense penalty from wearing armor by 1 (minimum 0). Ignores movement penalties for terrain while taking Movement Actions."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4FK3CombatTra01","name":"Combat Training","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Freikorpsmann","requirements":"Step 3","description":"Gains the following Trigger on Ranged Combat duels — M Reposition: After succeeding, this character may move up to 3 yards. Gains the following Trigger on Close Combat attacks — t Duck & Weave: After succeeding, this character increases her Defense by +1 until the start of her next turn."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4FK4EvrChngBtl1","name":"Ever-Changing Battlefield","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Freikorpsmann","requirements":"Step 4","description":"Gains the following Tactical Action — (0) Fighting Retreat: If this character is engaged, she may discard a card to move up to 4 yards in any direction, ignoring disengaging strikes. If the discarded card had a value of 6+, she may then take a 1 AP Ranged Combat Action."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4FK5SpecialistT","name":"Specialist Training","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Freikorpsmann","requirements":"Step 5","description":"The character chooses one of the following specializations: Librarian — Powder Wars Training now also affects Magical Challenges. The character is issued a heavy tome (a Grimoire containing the Heal Magia plus one Magia and three Immuto of the character's choice). If she does not have a Magical Theory, she gains the Tradition Magical Theory. Drache Trooper — The character is issued a Flamethrower and may use Flamethrowers as if their Range were 3 yards (in addition to their normal Range). Trapper — The character is issued a Yamisaka Type 30 Rifle. Whenever this character takes a (1) Walk Action during Dramatic Time, she gains Focused +1."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4GS1ServantDt01","name":"Servant of Death","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Grave Servant","requirements":"Step 1","description":"When this character transforms a corpse into an Undead subordinate using the Raise Undead Magia: the Undead's Mental Aspects are lowered to -3 (instead of -5); its Physical Aspects are not halved; its Rank Value becomes Minion (6)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4GS2EndlessWh01","name":"Endless Whispers","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Grave Servant","requirements":"Step 2","description":"At any point during Narrative Time, or at the start of her turn during Dramatic Time, this character may discard a card to choose a Necromancy Magia. Until the end of Dramatic Time or the current scene of Narrative Time, she has access to that Magia regardless of her current Grimoire. If she does not possess a Grimoire, she may act as if she possessed one containing that Magia."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4GS3ShadowDeat1","name":"Shadow of Death","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Grave Servant","requirements":"Step 3","description":"Gains the following Manifested Power — Shadow of Death (Necromancy + Prestidigitation, 2 AP, TN Special, Resist Wp, Range 10 yards). Special: When cast, name a type of Undead creature. The TN is 10MC + the Rank Value of the chosen creature. Effect: An Undead creature of the chosen type appears at a safe location within range and is placed under this character's control as a subordinate for the next hour. At the end of that time, the Undead creature becomes uncontrolled (and usually violent)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4GS4FinalVeil01","name":"The Final Veil","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Grave Servant","requirements":"Step 4","description":"When a non-Peon Living character is killed within aura 8 of this character, she heals 2 damage."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4GS5DeathAscnd1","name":"Death Ascendant","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Grave Servant","requirements":"Step 5","description":"Once per session as a (0) Action, this character draws upon the Grave Spirit's essence, cloaking herself in inky tendrils that lift her from the ground. While in this state: Gains +2 to Walk and Charge Aspects; Ignores Severe Terrain; Adds +C to all Magical Skill Challenges; Suffers 1 damage at the start of her turn; If a Living character ends a Walk Action within her engagement range or targets her with an Action, it must attempt a TN 12 Horror Duel. The character may end this effect as a (0) Action. While in this state, she also gains the attack: Inky Tendril (Necromancy, pulse 4, Damage 3/5/6). Special: This character must discard a card to declare this attack; Undead damaged by this attack instead heal the indicated amount of damage. Trigger — C The Touch of Death: After damaging a Living target, it must discard a card. If it does not, it loses the Living Characteristic and gains the Undead Characteristic as it dies and becomes an Undead creature. If the target was a Fatemaster character, it becomes a subordinate under this character's control."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4SF1CnstrPrws01","name":"Construct Prowess","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Steamfitter","requirements":"Step 1","description":"When building a Construct, each Construct Point spent to increase one of its Physical Aspects increases the Aspect by 2 points instead of 1."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4SF2ArcnstInit1","name":"Arcanist Initiation","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Steamfitter","requirements":"Step 2","description":"The character is formally inducted into the Arcanists and given additional magical training. She chooses one Magia and one Immuto. She always has access to this Magia and Immuto regardless of her current Grimoire. If she does not possess a Grimoire, she may act as if she possessed one containing this Magia and Immuto."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4SF3ArcnstCnt01","name":"Arcanist Contacts","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Steamfitter","requirements":"Step 3","description":"While in Malifaux City or the Northern Hills, this character may discard a card to find a safe place to hide, needed supplies, or knowledgeable contacts (e.g., medical supplies, extra weapons and ammunition, someone who can remove Guild Control Collars)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4SF4CnstrEffic1","name":"Construct Efficiency","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Steamfitter","requirements":"Step 4","description":"This character may treat the (1) Order Action as a (0) Action when commanding a subordinate Construct. Alternatively, she may treat the (1) Order Action as a (2) Action. If she does, the subordinate Construct becomes Fast at the start of its turn. If she can command multiple Constructs simultaneously, each becomes Fast."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4SF5GrmoireVlt1","name":"Grimoire Vault","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Steamfitter","requirements":"Step 5","description":"Once per session, this character may spend two hours meeting with a fellow Arcanist to request access to one of the organization's Grimoires. She chooses three Magia and three Immuto for the Grimoire, which is then loaned to her indefinitely. She must return the borrowed Grimoire before requesting a new one. If a borrowed Grimoire is lost or stolen, a different Grimoire may be substituted — though repeated losses may result in losing access to this Talent."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4TK1TenWeapns01","name":"The Ten Weapons of Wxu-Shu","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Torakage","requirements":"Step 1","description":"Before making an attack with one of the Ten Weapons of Wxu-Shu or the Martial Arts Skill, this character may name a suit and add it to her final duel total. The Ten Weapons include: Longbow (Archery, 12 yards, Damage 2/2/4, Arrow/Bow, 5§, Skill 1); Iron Whip (Flexible, 2 yards, Damage 2/3/4, Stunning, 25§, Skill 3); Kusari-gama (Flexible, 3 yards, Damage 2/2/3, Snaring, 7§, Skill 2); Meteor Hammer (Flexible, 2 yards, Damage 2/4/5, Brutal, 13§, Skill 2); Double-Edged Sword (Melee, 2 yards, Damage 2/3/5, Deadly, 12§, Skill 3); Single-Edged Sword (Melee, 2 yards, Damage 2/3/4, Precise, 25§, Skill 3); Greataxe (Heavy Melee, 2 yards, Damage 3/5/7, Enlarged/Intimidating, 20§, Skill 2); Spear (Heavy Melee, 3 yards, Damage 2/3/4, Precise, 4§, Skill 1); Staff (Heavy Melee, 2 yards, Damage 1/2/4, 1§, Skill 1)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4TK2WindsPath01","name":"The Wind's Path","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Torakage","requirements":"Step 2","description":"This character is immune to disengaging strikes. If pushed by any effect, she may increase or decrease the push distance by a number of yards equal to her Speed Aspect (minimum 1 yard)."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4TK3LeavesBrez1","name":"The Leaves Upon the Breeze","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Torakage","requirements":"Step 3","description":"This character can manufacture shuriken with great speed. These are Thrown Weapons with range 8 yards, the Fan special rule, dealing Damage 1/2/3. They can be crafted from almost any sharpenable material at a rate of 10 per hour of work. Gains the following Trigger on all Thrown Weapon attacks — M Leaf Steps: After resolving, move up to 3 yards."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4TK4FaclssKlr01","name":"Faceless Killer","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Torakage","requirements":"Step 4","description":"If this character's face is hidden behind a mask: Gains ++ to Intimidate Challenges; May not be the target of Charge Actions unless the charging character has the Relentless Talent."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"G4TK5Assassinat1","name":"Assassinate","type":"talent","img":"icons/magic/symbols/runes-star-orange.webp","system":{"pursuit":"Torakage","requirements":"Step 5","description":"Gains the following Trigger on any attack made with the Martial Arts Skill or any of the Ten Weapons of Wxu-Shu — CC Assassinate: After damaging, immediately kill the target unless it discards two cards."},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
