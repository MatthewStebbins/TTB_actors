{"_id":"BarbedWhip000000","name":"Barbed Whip","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"flexible","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":2,"damageSevere":4,"range":"y3","capacity":0,"reload":0,"triggers":"","special":"Stunning","description":"A whip with numerous small metal hooks or glass shards woven into its length, increasing damage to bare flesh. Thicker and heavier than a traditional whip — more painful but less flexible. Originally a human weapon later adopted by certain breeds of Nephilim.","equipped":false,"cost":15,"category":"flexible"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"DrivingWhip00001","name":"Driving Whip","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"flexible","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":2,"damageSevere":3,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"—","description":"Typically found with coachmen, beastmasters, or Guild taskmasters. Features a handle, a semi-flexible shaft (2-3 feet), and a longer lash. Normally used to signal direction and pace; capable of opening painful welts when used as a weapon.","equipped":false,"cost":2,"category":"flexible"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Flail00000000002","name":"Flail","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"flexible","apCost":1,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"—","description":"Originally a farming tool, now an uncommon weapon. Consists of one or more round or spiked metal heads attached to a short metal handle by chains. Not especially common in Malifaux or on Earth, but occasionally found in the hands of proficient users.","equipped":false,"cost":10,"category":"flexible"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Garrote000000003","name":"Garrote","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"flexible","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":2,"damageSevere":3,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Choking, Concealable, Deadly, Finely Tuned, Slowing","description":"An assassin's weapon for silent eliminations. A length of flexible but tough material (rope, cord, or piano wire) used to strangle a target from behind. Professional assassins often commission manufactured garrotes with custom handles.","equipped":false,"cost":1,"category":"flexible"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Lasso00000000004","name":"Lasso","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"flexible","apCost":1,"rangeType":"ranged","damageWeak":1,"damageMod":1,"damageSevere":2,"range":"z6","capacity":0,"reload":0,"triggers":"","special":"Finely Tuned, Deadly, Tether","description":"Primarily a cattle-herding tool, occasionally used in bounty hunting. A length of rope with a loop at one end, tossed around the target and pulled tight to restrain them.","equipped":false,"cost":1,"category":"flexible"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"BayonetRifle0005","name":"Bayonet (Rifle)","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"—","description":"Small knife-like blades that attach to the end of a rifle, transforming it into a crude spear. Designed not to interfere with firing, but experienced marksmen dislike the extra weight pulling the tip down.","equipped":false,"cost":4,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"BreachingAxe0006","name":"Breaching Axe","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Precise","description":"Issued by the Guild to personnel on Quarantine Zone duty. These large, two-handed axes are specially designed to tear through wood and stone walls — and are equally effective against shambling zombies.","equipped":false,"cost":18,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"GateSpear0000007","name":"Gate Spear","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Thrown","description":"Named for their frequent use by Guild gate guards. Their long reach and ability to be thrown at fleeing enemies makes them versatile and popular.","equipped":false,"cost":8,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Greatsword000008","name":"Greatsword","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":3,"damageMod":4,"damageSevere":6,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Brutal, Intimidating","description":"Any sword too large to wield with one hand. Can be broad or thin; all are capable of dealing significant destruction.","equipped":false,"cost":22,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Polearm000000009","name":"Polearm","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"y3","capacity":0,"reload":0,"triggers":"","special":"—","description":"Any blade attached to a long handle. Considered outdated since the rise of firearms, but popular among Nephilim hunters — the long reach helps the wielder avoid being splashed with corrosive Black Blood.","equipped":false,"cost":18,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"RailHammer000010","name":"Rail Hammer","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":2,"damageMod":4,"damageSevere":6,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"—","description":"Massive two-handed hammers primarily used to drive iron spikes when laying railroad tracks.","equipped":false,"cost":6,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Staff00000000011","name":"Staff","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"heavy_melee","apCost":2,"rangeType":"melee","damageWeak":1,"damageMod":2,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"—","description":"Any large walking stick, fancy or plain. A frequent travel companion for those making long journeys.","equipped":false,"cost":1,"category":"heavy_melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"BayonetPisto0012","name":"Bayonet (Pistol)","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"—","description":"Small blades that attach to a pistol at the barrel or around the grip. Allow a gunslinger to defend herself in close quarters without holstering her pistol.","equipped":false,"cost":3,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Club000000000013","name":"Club","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":2,"damageMod":2,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Stunning","description":"Any one-handed bludgeoning weapon. Simple and prolific — crude, but effective.","equipped":false,"cost":4,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"HandAxe000000014","name":"Hand Axe","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Thrown","description":"A light, all-purpose tool that works as well in combat as it does cutting firewood or rope.","equipped":false,"cost":2,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"HuntingKnife0015","name":"Hunting Knife","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Concealable","description":"Popular across Malifaux, especially in the Northern Hills. Some have small tools built into the handle, typically adding the price of a skill toolkit to the cost.","equipped":false,"cost":2,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Javelin000000016","name":"Javelin","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Slowing, Thrown","description":"Light spears primarily designed to be thrown. Considered an outdated relic but still effective for those who avoid gun maintenance. Designed to stick in wounds and slow the target until removed.","equipped":false,"cost":5,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Sword00000000017","name":"Sword","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"—","description":"Encompasses all one-handed swords regardless of construction. Expensive due to the steel required, but reliable and capable of significant damage in trained hands.","equipped":false,"cost":10,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Truncheon0000018","name":"Truncheon","type":"weapon","img":"icons/weapons/swords/sword-guard-purple.svg","system":{"attackSkill":"melee","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Stunning","description":"A staple of constabulary forces worldwide, including the Guild. Designed to stun and confuse enemies the Guild would rather capture alive.","equipped":false,"cost":3,"category":"melee"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"PneumaticBon0019","name":"Pneumatic Bonesaw","type":"weapon","img":"icons/weapons/axes/axe-battle.svg","system":{"attackSkill":"pneumatic","apCost":1,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Brutal, Finely Tuned, Penetrating","description":"A spinning blade attached to a pneumatic backpack power supply. Originally a surgeon's tool, now pressed into combat service — most notably by the Abyssinian armed forces.","equipped":false,"cost":35,"category":"pneumatic"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"PneumaticDri0020","name":"Pneumatic Drill","type":"weapon","img":"icons/weapons/axes/axe-battle.svg","system":{"attackSkill":"pneumatic","apCost":2,"rangeType":"melee","damageWeak":4,"damageMod":5,"damageSevere":7,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Finely Tuned, Heavy, Penetrating","description":"Motorized drills designed to quickly bore through solid rock. Heavy and unwieldy as weapons. Most commonly see combat use when an unlucky miner ends up with one attached to a pneumatic limb.","equipped":false,"cost":40,"category":"pneumatic"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"RailDriver000021","name":"Rail Driver","type":"weapon","img":"icons/weapons/axes/axe-battle.svg","system":{"attackSkill":"pneumatic","apCost":1,"rangeType":"melee","damageWeak":2,"damageMod":4,"damageSevere":5,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Finely Tuned, Penetrating, Thrown","description":"A bulky rivet gun used to sink rivets into steel rails. The weapon itself cannot be thrown, but the pressurized rivets can be fired like a pneumatic gun.","equipped":false,"cost":30,"category":"pneumatic"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"USEChainsaw00022","name":"US&E Chainsaw","type":"weapon","img":"icons/weapons/axes/axe-battle.svg","system":{"attackSkill":"pneumatic","apCost":1,"rangeType":"melee","damageWeak":3,"damageMod":4,"damageSevere":5,"range":"y2","capacity":0,"reload":0,"triggers":"","special":"Brutal, Finely Tuned","description":"Originally developed for quickly cutting down trees. Its brutal nature has made it popular among those who do frequent battle with the walking dead.","equipped":false,"cost":40,"category":"pneumatic"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"WeldingTorch0023","name":"Welding Torch","type":"weapon","img":"icons/weapons/axes/axe-battle.svg","system":{"attackSkill":"pneumatic","apCost":1,"rangeType":"melee","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Finely Tuned, Flaming, Penetrating","description":"Initially designed to weld metal. Capable of producing and maintaining a flame burning at approximately 3,500 degrees Celsius.","equipped":false,"cost":40,"category":"pneumatic"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"FightingClaw0024","name":"Fighting Claw","type":"weapon","img":"icons/weapons/fist/fist.svg","system":{"attackSkill":"pugilism","apCost":1,"rangeType":"melee","damageWeak":1,"damageMod":3,"damageSevere":4,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Fistload","description":"Leather or metal gloves with attached metal blades, based on the natural claws of beasts. Can be used as slashing weapons or in combination with unarmed attacks.","equipped":false,"cost":8,"category":"pugilism"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Knuckleduste0025","name":"Knuckleduster","type":"weapon","img":"icons/weapons/fist/fist.svg","system":{"attackSkill":"pugilism","apCost":1,"rangeType":"melee","damageWeak":0,"damageMod":0,"damageSevere":0,"range":"y1","capacity":0,"reload":0,"triggers":"","special":"Concealable, Finely Tuned, Fistload","description":"Essentially brass knuckles. Focuses and concentrates the force of unarmed attacks, turning even a simple punch into a dangerous strike. Damage is special — adds to unarmed damage rather than replacing it.","equipped":false,"cost":1,"category":"pugilism"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"AGHarpoonGun0026","name":"AG Harpoon Gun","type":"weapon","img":"icons/weapons/thrown/arrow.svg","system":{"attackSkill":"archery","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":4,"damageSevere":6,"range":"z12","capacity":1,"reload":2,"triggers":"","special":"Slowing, Special Ammo, Tether","description":"The weapon of choice for hunters of the Cult of December. Cultists added a modification allowing a strong rope to be attached to the harpoon for reeling in struck targets. AG Works incorporated this modification into all subsequent models; now popular among hunters of all stripes.","equipped":false,"cost":14,"category":"archery"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Blowgun000000027","name":"Blowgun","type":"weapon","img":"icons/weapons/thrown/arrow.svg","system":{"attackSkill":"archery","apCost":1,"rangeType":"ranged","damageWeak":1,"damageMod":1,"damageSevere":2,"range":"z6","capacity":1,"reload":1,"triggers":"","special":"Concealable, Special Ammo","description":"A hollow tube roughly 2 feet long that propels a small dart by blowing into it. The dart itself is not especially dangerous — it is almost always coated in poison prior to firing.","equipped":false,"cost":4,"category":"archery"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"ClockworkBow0028","name":"Clockwork Bow","type":"weapon","img":"icons/weapons/thrown/arrow.svg","system":{"attackSkill":"archery","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":6,"reload":3,"triggers":"","special":"Full Auto","description":"Based on the Chu-Ko-Nu of the Three Kingdoms. Holds six bolts preloaded into a top-mounted magazine. Internal pulleys automatically nock a new bolt after each shot, enabling rapid fire.","equipped":false,"cost":35,"category":"archery"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Crossbow00000029","name":"Crossbow","type":"weapon","img":"icons/weapons/thrown/arrow.svg","system":{"attackSkill":"archery","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":4,"damageSevere":6,"range":"z18","capacity":1,"reload":2,"triggers":"","special":"Penetrating","description":"A mechanical weapon sharing more in common with a rifle than a traditional bow. A bolt is loaded and winched back for great force. In skilled hands, can match some firearms in effectiveness, especially against armored targets.","equipped":false,"cost":15,"category":"archery"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Longbow000000030","name":"Longbow","type":"weapon","img":"icons/weapons/thrown/arrow.svg","system":{"attackSkill":"archery","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":2,"damageSevere":4,"range":"z12","capacity":0,"reload":0,"triggers":"","special":"Bow, Indirect","description":"A mainstay of warfare for thousands of years until the rifle's invention. Still a popular hunting tool in Malifaux's wilds, where a rifle's loud report can attract things far more deadly than a sleepy bear.","equipped":false,"cost":10,"category":"archery"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Shortbow00000031","name":"Shortbow","type":"weapon","img":"icons/weapons/thrown/arrow.svg","system":{"attackSkill":"archery","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":2,"damageSevere":3,"range":"z8","capacity":0,"reload":0,"triggers":"","special":"Bow, Indirect","description":"A smaller version of the longbow. Less range and stopping power, but easier to maintain and requires less practice — popular among those who only dabble in archery.","equipped":false,"cost":4,"category":"archery"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"AlpineGatlin0032","name":"Alpine Gatling Gun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"heavy_guns","apCost":2,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"z20","capacity":50,"reload":4,"triggers":"","special":"Deadly, Full Auto, Heavy","description":"One of Alpine's first weapons — an attempt to scale down a mobile Gatling gun for personal use. Still requires the provided brace. Initially banned by the Guild, Alpine eventually negotiated permits for purchase at roughly half the weapon's cost; owners are added to the Governor-Secretary's special lists.","equipped":false,"cost":45,"category":"heavy_gun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Flamethrower0033","name":"Flamethrower","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"heavy_guns","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z10","capacity":20,"reload":8,"triggers":"","special":"Flaming, Intimidating, Special Ammo","description":"A product of the Black Powder Wars, rarely fielded but notorious. The Freikorps have special permission to carry them; all other possession is illegal. Capable of projecting a sustained stream of fire.","equipped":false,"cost":75,"category":"heavy_gun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"GrenadeLaunc0034","name":"Grenade Launcher","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"heavy_guns","apCost":1,"rangeType":"ranged","damageWeak":3,"damageMod":3,"damageSevere":6,"range":"z12","capacity":4,"reload":4,"triggers":"","special":"Multi-Barrel, Special Ammo","description":"An illegal weapon from the Black Powder Wars era. Launches an explosive payload like a rifle bullet. Banned in Malifaux.","equipped":false,"cost":80,"category":"heavy_gun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Model1866Six0035","name":"Model 1866 Six Pounder","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"heavy_guns","apCost":2,"rangeType":"ranged","damageWeak":5,"damageMod":7,"damageSevere":9,"range":"z50","capacity":1,"reload":6,"triggers":"","special":"Heavy, Loader","description":"A tried-and-true cannon mounted on a two-wheeled carriage. The Guild keeps dozens in reserve; private ownership is outlawed in Malifaux.","equipped":false,"cost":500,"category":"heavy_gun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"MortarGun0000036","name":"Mortar Gun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"heavy_guns","apCost":2,"rangeType":"ranged","damageWeak":5,"damageMod":6,"damageSevere":7,"range":"z50","capacity":1,"reload":2,"triggers":"","special":"Heavy, Indirect, Special Ammo","description":"Outlawed by the Guild, but a handful sneak through the Breach each year. Fires an explosive round in an arc, allowing it to go over obstacles to reach targets.","equipped":false,"cost":100,"category":"heavy_gun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"OnePounderSw0037","name":"One-Pounder Swivel Gun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"heavy_guns","apCost":2,"rangeType":"ranged","damageWeak":5,"damageMod":7,"damageSevere":9,"range":"z18","capacity":1,"reload":6,"triggers":"","special":"Heavy, Loader","description":"A small cannon typically mounted on pintles on boats or large wagons. Aimed via a rod attached to the breech; usually loaded with grapeshot and easy to load and fire.","equipped":false,"cost":100,"category":"heavy_gun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"ATModel100000038","name":"A&T Model 10","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":1,"damageMod":2,"damageSevere":4,"range":"z12","capacity":1,"reload":2,"triggers":"","special":"Blunderbuss","description":"The larger sibling to A&T's Drakon pistol. Manufactured in Malifaux by Alexeivich & Tocharof Weaponsmiths Ltd. A blunderbuss capable of firing virtually anything that fits in the barrel — lead shot, nails, scrap metal, glass shards, small rocks. Ideal for remote areas where standard ammunition may be unavailable.","equipped":false,"cost":3,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"AlpineMachin0039","name":"Alpine Machine Gun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"z12","capacity":18,"reload":4,"triggers":"","special":"Deadly, Full Auto","description":"The result of Alpine's efforts to scale their Gatling gun down even further. A resounding success — now considered the best personal machine gun on the market. Demand is so high that Alpine opened a second factory to meet orders from Earth's governments.","equipped":false,"cost":25,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Chesterfield0040","name":"Chesterfield 1879","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"z18","capacity":10,"reload":3,"triggers":"","special":"Rifle","description":"Simple, reliable, and portable — and outlawed by the Guild. Legend holds that the Guild raided and destroyed the Chesterfield factories after the owner refused to sell at Guild-set prices. The 1879 models are said to carry the owner's dying curse, with every bullet finding its way to a Guild employee's heart.","equipped":false,"cost":14,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"CollierLight0041","name":"Collier Lightning 1902","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":3,"damageMod":3,"damageSevere":4,"range":"z18","capacity":12,"reload":2,"triggers":"","special":"Rifle","description":"A lightweight pump-action carbine fed by a round magazine. Originally marketed to law enforcement as a rifle/shotgun hybrid. Overpriced at launch, and sales never fully recovered. Primarily found in Malifaux in the hands of wealthy hunters and treasure hunters.","equipped":false,"cost":20,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"EnfieldMuske0042","name":"Enfield Musketoon","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z16","capacity":1,"reload":2,"triggers":"","special":"Rifle","description":"A series of popular single-shot, muzzle-loading muskets from the Royal Small Arms Factory in London. Once standard-issue to British cavalry and artillery; now showing their age. Affordable and popular among budget-conscious adventurers and smaller nations.","equipped":false,"cost":5,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"HawkenRifle00043","name":"Hawken Rifle","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"z16","capacity":1,"reload":3,"triggers":"","special":"Rifle","description":"Renowned for durability and accuracy. Features a double set of triggers — pulling the rear trigger sets the front trigger into an extremely sensitive hair trigger. Beloved by frontiersmen; seen as a symbol of oppression by the displaced native tribes of the American Midwest.","equipped":false,"cost":5,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"HowlesPatter0044","name":"Howles Pattern 1874","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":3,"damageMod":5,"damageSevere":6,"range":"z24","capacity":1,"reload":1,"triggers":"","special":"Rifle","description":"The most popular of the long-running Howles family of large single-shot rifles. Exceptional range and firepower even compared to modern weapons. Increasingly difficult to acquire as they are now priced more as collector's items than combat rifles.","equipped":false,"cost":20,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"NockVolleyGu0045","name":"Nock Volley Gun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":7,"reload":4,"triggers":"","special":"Multi-Barrel","description":"A seven-barrel pepperbox designed by the British Royal Navy to repel boarding parties. Cumbersome and slow to reload, but capable of unleashing extraordinary destruction in a single salvo of .52 caliber slugs. Popular among retired Navy officers turned river captains in Malifaux.","equipped":false,"cost":20,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"YamisakaType0046","name":"Yamisaka Type 30","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"long_arms","apCost":1,"rangeType":"ranged","damageWeak":3,"damageMod":4,"damageSevere":5,"range":"z18","capacity":5,"reload":2,"triggers":"","special":"Rifle","description":"Released in the mid-1890s and quickly adopted as a standard infantry rifle by the Guild and many Earth powers. Long barrel, strong action, light recoil, and excellent balance. Still considered one of the best rifles on the market a decade after release.","equipped":false,"cost":22,"category":"long_arm"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"ATDrakon00000047","name":"A&T Drakon","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":1,"damageMod":2,"damageSevere":4,"range":"z6","capacity":1,"reload":2,"triggers":"","special":"Blunderbuss","description":"A pistol-sized blunderbuss known as a hand cannon. Can be loaded with nails, scrap metal, or other improvised projectiles. Suffers from its compact size — limited range and force. Manufactured by Alexeivich & Tocharof Weaponsmiths Ltd. in Malifaux.","equipped":false,"cost":5,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"AxtonCoModel0048","name":"Axton & Co. Model 1842","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z10","capacity":1,"reload":2,"triggers":"","special":"—","description":"Mostly military surplus from the U.S. Army arsenal at Rock Island, Illinois. A single-fire relic of another era. Features an oiled walnut stock, brass furniture, and dark blued barrel. Inexpensive and widely available.","equipped":false,"cost":3,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"BDGatlingDer0049","name":"B&D Gatling Derringer","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":3,"range":"z6","capacity":9,"reload":2,"triggers":"","special":"Burst Fire, Concealable","description":"Uses the same firing mechanism as a Gatling gun, scaled down to pistol size. Fires from a nine-round replaceable drum. Small enough to conceal in a boot or purse — an effective backup weapon by Blackheel & Doyle.","equipped":false,"cost":20,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"BDPocket00000050","name":"B&D Pocket","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":3,"range":"z6","capacity":4,"reload":2,"triggers":"","special":"Concealable","description":"A small Blackheel & Doyle revolver designed to be concealed in a pocket or purse. Despite its size, it is a legitimate weapon — an excellent sidearm for a forward-thinking socialite.","equipped":false,"cost":7,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"ClockworkPis0051","name":"Clockwork Pistol","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":4,"damageSevere":5,"range":"z12","capacity":6,"reload":2,"triggers":"","special":"—","description":"Considered a gentleman's weapon, typically used only in self-defense. Notable exception: the Freikorps mercenary group, for whom it is standard issue.","equipped":false,"cost":20,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"CollierNavy00052","name":"Collier Navy","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":6,"reload":2,"triggers":"","special":"—","description":"A double-action revolver designed as a more user-friendly companion to the Rough Rider. One of the most ubiquitous pistols in the world. Despite the name, never officially issued to any naval forces — named instead for the Battle of Alcatraz engraving on the cylinder.","equipped":false,"cost":9,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"CollierRough0053","name":"Collier Rough Rider","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z10","capacity":6,"reload":2,"triggers":"","special":"Fan","description":"The Model 1848 Percussion Army Revolver, known as the Rough Rider. Named after the American cavalry unit of the second American-Texan War. Synonymous with American exceptionalism. Features the Fan special ability.","equipped":false,"cost":19,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"MaucherThree0054","name":"Maucher Three-Barrel","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":2,"damageSevere":5,"range":"z6","capacity":3,"reload":4,"triggers":"","special":"Multi-Barrel","description":"One of the first pistols manufactured in Malifaux. A lightweight pepperbox with three barrels. Slightly awkward but affordable and popular.","equipped":false,"cost":14,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Peacebringer0055","name":"Peacebringer","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"z10","capacity":6,"reload":1,"triggers":"","special":"Intimidating","description":"The signature firearm of the Guild. Standard issue to Death Marshals; popular among Nephilim Hunters and Witch Hunters. Large, intimidating, high-caliber, and highly accurate. Nearly all models include a bayonet. Not sold on the open market — possession by non-Guild members is illegal.","equipped":false,"cost":27,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"VolyerRevolv0056","name":"Volyer Revolving","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z10","capacity":7,"reload":4,"triggers":"","special":"—","description":"Designed by Elisha Volyer; produced by Marley Evens & Sons of London for the Royal Army. One of the earliest revolvers available to the public — technically a multi-cylinder single-shot rather than a true revolver. Awkward to load by modern standards but sturdy and reliable.","equipped":false,"cost":8,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"WeshornSmitt0057","name":"Weshorn & Smitte #3","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock.svg","system":{"attackSkill":"pistol","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":6,"reload":1,"triggers":"","special":"—","description":"First produced in 1870 as a direct competitor to Collier's revolvers. Officially produced for armies in North America, South America, and Europe. Many have ended up in outlaw hands over the years, tarnishing an otherwise solid reputation.","equipped":false,"cost":19,"category":"pistol"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"AGRiotGun0000058","name":"AG Riot Gun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z10","capacity":10,"reload":3,"triggers":"","special":"Shot, Slowing","description":"Commissioned by the Guild to clear striking miners or protestors without killing them. Shorter barrel and increased capacity over most shotguns. Shot can be ricocheted off the ground for non-lethal but wide-spread effect — while still capable of putting down zombies or enraged Nephilim.","equipped":false,"cost":19,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"AlpineAutoma0059","name":"Alpine Automatic Shotgun","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":12,"reload":4,"triggers":"","special":"Shot","description":"Alpine's attempt to improve shotgun fire rate. Revolving chambers increase capacity without sacrificing stopping power. Higher cost and longer reload time are the trade-offs. One of the better shotguns money can buy.","equipped":false,"cost":35,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Chesterfield0060","name":"Chesterfield Model 1887","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":5,"range":"z12","capacity":5,"reload":3,"triggers":"","special":"Intimidating, Shot","description":"Produced after the Guild took over Chesterfield Repeating Arms. One of the first practical repeating shotguns on the market. Quickly adopted by law enforcement and stagecoach companies. Efficient, deadly, and intimidating.","equipped":false,"cost":19,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"Chesterfield0061","name":"Chesterfield Model 1897","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":3,"damageMod":4,"damageSevere":5,"range":"z12","capacity":5,"reload":3,"triggers":"","special":"Shot","description":"An improved version of the 1887 with a stronger receiver, lengthened stock, and heat shield. Considered one of the finest shotguns ever made — but too expensive for widespread adoption.","equipped":false,"cost":29,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"CollierHamme0062","name":"Collier Hammerless","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z10","capacity":2,"reload":1,"triggers":"","special":"Multi-Barrel, Shot","description":"Collier's premier shotgun. Hammers and firing mechanisms are fully internal. Breaking open the action automatically ejects spent shells. A landmark in shotgun design that spawned many imitators, none of which improved upon the original.","equipped":false,"cost":8,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"FlintlockBoo0063","name":"Flintlock Boomer 1894","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":4,"damageSevere":5,"range":"z9","capacity":1,"reload":3,"triggers":"","special":"Blunderbuss, Intimidating","description":"An imposing, destructive weapon infamous for its association with the Gremlin Som'er Teeth Jones, who has used it in bloody raids throughout the western Bayou. The association has damaged the already-struggling Flintlock company's reputation.","equipped":false,"cost":9,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"SolbergInert0064","name":"Solberg Inertia","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":6,"reload":3,"triggers":"","special":"Shot","description":"Designed by Avlin Solberg and produced in Denmark. The first self-loading sporting shotgun, using Solberg's patented Inertia action. Only needs to be cocked once; operates on a principle similar to double-action pistols and rifles.","equipped":false,"cost":9,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
{"_id":"USEPumpActio0065","name":"US&E Pump Action","type":"weapon","img":"icons/weapons/guns/gun-pistol-flintlock-dual.svg","system":{"attackSkill":"shotgun","apCost":1,"rangeType":"ranged","damageWeak":2,"damageMod":3,"damageSevere":4,"range":"z12","capacity":4,"reload":2,"triggers":"","special":"Shot","description":"The ubiquitous, reliable, affordable no-frills shotgun. Popular among stagecoach drivers and frontier lawmen. Considered an excellent weapon for its price.","equipped":false,"cost":4,"category":"shotgun"},"effects":[],"folder":null,"sort":0,"ownership":{},"flags":{}}
